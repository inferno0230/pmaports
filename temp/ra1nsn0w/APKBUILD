414c21cc6dee1cadf62c7368e1302242975e4dd680bbb1cc46a629403dcdde167c12c40944fe15de7df7d2748a020e2f2cd8d04525444b508a4d79d05a6478c2  0001-shim-strtoul_l.patch
"
