From a6cedc29fb4467e521442ab56bcfd829dfa41679 Mon Sep 17 00:00:00 2001
From: Achill Gilgenast <achill@achill.org>
Date: Wed, 6 May 2026 12:27:53 +0200
Subject: [PATCH] data: Use oo7-portal as secret portal

GNOME is likely going to switch to oo7 too.

Signed-off-by: Achill Gilgenast <achill@achill.org>
---
 data/phosh-portals.conf | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/data/phosh-portals.conf b/data/phosh-portals.conf
index 3bf377d27..e0055b3e5 100644
--- a/data/phosh-portals.conf
+++ b/data/phosh-portals.conf
@@ -8,5 +8,5 @@ org.freedesktop.impl.portal.InputCapture=none;
 org.freedesktop.impl.portal.RemoteDesktop=none;
 org.freedesktop.impl.portal.ScreenCast=wlr;
 org.freedesktop.impl.portal.Screenshot=gtk;wlr;
-org.freedesktop.impl.portal.Secret=gnome-keyring;
+org.freedesktop.impl.portal.Secret=oo7-portal;gnome-keyring;
 org.freedesktop.impl.portal.Usb=none;
-- 
