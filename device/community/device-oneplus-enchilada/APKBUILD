# Reference: <https://postmarketos.org/devicepkg>
maintainer="Casey Connolly <kcxt@postmarketos.org>"
pkgname=device-oneplus-enchilada
pkgdesc="OnePlus 6"
pkgver=26
pkgrel=0
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	alsa-ucm-conf-sdm845
	firmware-oneplus-sdm845>=9
	firmware-oneplus-sdm845-sensors
	hexagonrpcd>=0.3.2-r3
	linux-postmarketos-qcom-sdm845
	mkbootimg
	postmarketos-base
	soc-qcom
	soc-qcom-modem
	soc-qcom-pd-mapper
	soc-qcom-qbootctl
	systemd-boot
	unl0kr-fbforcerefresh
"
makedepends="devicepkg-dev"
source="
	alsa-restore-override.conf
	alsa-state-override.conf
	deviceinfo
	hexagonrpcd.confd
	kernel-cmdline.conf
	modules-initfs
	q6voiced.conf
"
install="
	$pkgname-openrc.post-install
	$pkgname-openrc.post-upgrade
	$pkgname-systemd.post-upgrade
"
subpackages="
	$pkgname-pmtest
	$pkgname-openrc
	$pkgname-systemd
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	replaces="$pkgname-nonfree-firmware"
	devicepkg_package $startdir $pkgname

	install -Dm644 "$srcdir"/q6voiced.conf \
		"$pkgdir"/etc/conf.d/q6voiced
	install -Dm644 "$srcdir"/hexagonrpcd.confd \
		"$pkgdir"/usr/share/hexagonrpcd/hexagonrpcd-sdsp.conf

	install -Dm644 "$srcdir"/alsa-restore-override.conf \
		"$pkgdir"/usr/lib/systemd/system/alsa-restore.service.d/override.conf
	install -Dm644 "$srcdir"/alsa-state-override.conf \
		"$pkgdir"/usr/lib/systemd/system/alsa-state.service.d/override.conf
}

openrc() {
	install_if="$pkgname=$pkgver-r$pkgrel openrc"
	depends="hexagonrpcd-openrc"
	mkdir -p "$subpkgdir"
}

pmtest() {
	depends="postmarketos-test-bootrr qrtr firmware-oneplus-sdm845 postmarketos-test-unl0kr"
	install_if="$pkgname=$pkgver-r$pkgrel postmarketos-mkinitfs-hook-ci"

	mkdir -p "$subpkgdir"
}

