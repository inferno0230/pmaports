# Co-Maintainer: Ingo Reitz <9l@9lo.re>
# Co-Maintainer: WeirdTreeThing <bradyn127@protonmail.com>
maintainer="Alicja Michalska <ellyqw@mainlining.org>"
pkgname=device-google-trogdor
pkgdesc="Google Trogdor Chromebooks"
pkgver=11
pkgrel=1
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	alsa-ucm-conf
	depthcharge-tools
	postmarketos-base
	postmarketos-cros-common
	soc-qcom-sc7180
"

makedepends="devicepkg-dev"
subpackages="
	$pkgname-nonfree-firmware:nonfree_firmware
	$pkgname-kernel-stable:kernel_stable
	$pkgname-kernel-lts:kernel_lts
	$pkgname-kernel-mainline:kernel_mainline
"
_pmb_recommends="
	$pkgname-kernel-lts
"

kernel_stable() {
	pkgdesc="Stable kernel (recommended, best balance between stability and features)"
	depends="linux-postmarketos-stable"
	devicepkg_subpackage_kernel $startdir $pkgname $subpkgname
}

kernel_lts() {
	pkgdesc="Long-term maintainance kernel (most stability, not all security fixes & new features)"
	depends="linux-postmarketos-lts"
	devicepkg_subpackage_kernel $startdir $pkgname $subpkgname
}

kernel_mainline() {
	pkgdesc="Upstream development kernel (regular breakage, latest features)"
	depends="linux-postmarketos-mainline"
	devicepkg_subpackage_kernel $startdir $pkgname $subpkgname
}

source="
	deviceinfo
	kernel-cmdline.conf
	modules-initfs
	99-google-trogdor-accel.rules
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname
	install -Dm644 "$srcdir"/99-google-trogdor-accel.rules\
			"$pkgdir"/usr/lib/udev/rules.d/99-google-trogdor-accel.rules
}

nonfree_firmware() {
	pkgdesc="WiFi/BT, Modem, GPU, Venus firmware"
	depends="
		linux-firmware-qcom
		linux-firmware-qca
		linux-firmware-ath10k
		firmware-google-trogdor
		soc-qcom-sc7180-nonfree-firmware
		msm-cros-efs-loader
	"
	mkdir "$subpkgdir"
}

openrc() {
	install_if="$pkgname=$pkgver-r$pkgrel openrc"
	depends="eudev-hwids"
	mkdir "$subpkgdir"
}

