maintainer="Joel Selvaraj <foss@joelselvaraj.com>"
pkgname=firmware-xiaomi-beryllium
pkgver=12
pkgrel=0
_commit="d396d32118803235a58aab0d0bc3643256634a05"
pkgdesc="Firmware for Xiaomi Poco F1"
url="https://gitlab.com/sdm845-mainline/firmware-xiaomi-beryllium"
arch="aarch64"
depends="linux-firmware-qcom linux-firmware-qca linux-firmware-ath10k"
license="proprietary"
subpackages="$pkgname-sensors:firmware_sensors"
source="$pkgname-$_commit.tar.gz::https://gitlab.com/sdm845-mainline/firmware-xiaomi-beryllium/-/archive/$_commit/firmware-xiaomi-beryllium-$_commit.tar.gz
	firmware.files
	firmware-initramfs.files
	mount-matrix.patch
	sensor.files
	"
options="!archcheck !strip !check !tracedeps pmb:cross-native textrels"
builddir="$srcdir/$pkgname-$_commit"

package() {
	while IFS="" read -r _i || [ -n "$_i" ]; do
		local _u="${_i/usr\/lib/\/lib}"
		[ ! -d "$(dirname $_i)" ] && mkdir -p "$(dirname "$pkgdir"/$_i)"
		install -Dm644 ."$_u" "$pkgdir/$_i"
	done < "$srcdir/firmware.files"

	install -Dm644 "$srcdir"/firmware-initramfs.files \
		"$pkgdir"/usr/share/mkinitfs/files/"$pkgname".files
}

firmware_sensors() {
	pkgdesc="Files to be included to add sensor support"
	depends="$pkgname"
	install_if="$pkgname-nonfree-firmware"
	mkdir "$subpkgdir"

	cd "$builddir"
	while IFS="" read -r _i || [ -n "$_i" ]; do
		local _u="${_i/usr\/lib/\/lib}"
		[ ! -d "$(dirname $_i)" ] && mkdir -p "$(dirname "$pkgdir"/$_i)"
		install -Dm644 ."$_u" "$subpkgdir/$_i"
	done < "$srcdir/sensor.files"
}

