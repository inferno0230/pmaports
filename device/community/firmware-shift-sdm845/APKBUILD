maintainer="Alexander Martinz <amartinz@shiftphones.com>"
pkgname=firmware-shift-sdm845
pkgver=20260428
pkgrel=2
_commit="a3ff3738b8ba541561d790b84f6ee82b28ed5d43"
pkgdesc="Firmware for SHIFT sdm845 devices"
url="https://gitlab.com/sdm845-mainline/firmware-shift-sdm845"
arch="aarch64"
depends="
	linux-firmware-ath10k
	linux-firmware-qcom
	"
license="proprietary"
subpackages="
	$pkgname-pmtest
	$pkgname-sensors:firmware_sensors
	"
# Textrels appear in DSP libraries which we cannot avoid
options="!archcheck !check !strip !tracedeps pmb:cross-native textrels"
source="$pkgname-$_commit.tar.gz::https://gitlab.com/sdm845-mainline/firmware-shift-sdm845/-/archive/$_commit/firmware-shift-sdm845-$_commit.tar.gz
	30-shift-sdm845-firmware-ci.files
	firmware.files
	firmware-initramfs.files
	sensors.files
	"
builddir="$srcdir/$pkgname-$_commit"

package() {
	while IFS="" read -r _i || [ -n "$_i" ]; do
		local _u="${_i/usr\/lib/lib}"
		[ ! -d $(dirname $_i) ] && mkdir -p $(dirname "$pkgdir"/$_i)
		install -Dm644 "$builddir""$_u" "$pkgdir/$_i"
	done < "$srcdir/firmware.files"

	install -Dm644 "$srcdir"/firmware-initramfs.files \
		"$pkgdir"/usr/share/mkinitfs/files/"$pkgname".files

	# Install symlinks for using upstream firmware
	ln -s ../../mba.mbn.zst "$pkgdir"/usr/lib/firmware/qcom/sdm845/SHIFT/axolotl/mba.mbn.zst
	ln -s ../../../../ath10k/WCN3990/hw1.0/wlanmdsp.mbn.zst "$pkgdir"/usr/lib/firmware/qcom/sdm845/SHIFT/axolotl/wlanmdsp.mbn.zst
}

pmtest() {
	install_if="$pkgname=$pkgver-r$pkgrel postmarketos-mkinitfs-hook-ci"

	install -Dm644 "$srcdir/30-shift-sdm845-firmware-ci.files" \
		"$subpkgdir/usr/share/mkinitfs/files/30-shift-sdm845-firmware-ci.files"
}

firmware_sensors() {
	pkgdesc="Firmware files of the sensor registry"
	depends="$pkgname"
	install_if="$pkgname-nonfree-firmware"
	mkdir "$subpkgdir"

	cd "$builddir"
	while IFS="" read -r _i || [ -n "$_i" ]; do
		local _u="${_i/usr\/lib/\/lib}"
		[ ! -d $(dirname $_i) ] && mkdir -p $(dirname "$subpkgdir"/$_i)
		install -Dm644 .$_u "$subpkgdir/$_i"
	done < "$srcdir/sensors.files"
}

