5c28e5fc50329faf6d9064c509aceebe7d24ccd9186144237fde6e8b20613ed7c5f6b72e31d1d4ec9798654e28a266d52ea9764fba9ee8a70eb5bbce9448fb84  config-samsung-coreprimevelte.aarch64
"
