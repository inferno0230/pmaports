+				dst_clip->y1 * pixel_pitch + dst_start_x;
+	const u8 *src = vaddr + src_clip->y1 * rgb_pitch +
+			src_start_x * fb->format->cpp[0];
+	const u8 *ioctl_hints =
+		ebc->hints_ioctl + src_clip->y1 * pixel_pitch + src_start_x;
