 include/drm/drm_blend.h                   |  4 ++-
 include/drm/drm_crtc.h                    | 12 ++++++++
 include/drm/drm_mode_config.h             |  5 +++
 include/uapi/drm/drm_mode.h               | 36 ++++++++++++++++++++++
