maintainer="Neil Armstrong <neil.armstrong@linaro.org>"
pkgname=firmware-ayaneo-pocket
pkgver=20251207
pkgrel=1
_commit="17fd5306f1dd33356f0bf85e2781f5c31e98ba0e"
pkgdesc="Firmware for Ayaneo Pocket"
url="https://github.com/sunflower2333/linux-firmware-ayaneo"
arch="aarch64"
license="proprietary"
makedepends="zstd"
subpackages="
	$pkgname-s2-adreno:s2_adreno
	$pkgname-s2-adsp:s2_adsp
	$pkgname-s2-ath12k:s2_ath12k
	$pkgname-s2-cdsp:s2_cdsp
	$pkgname-s2-iris:s2_iris
	$pkgname-s2-tplg:s2_tplg
	$pkgname-renesas-usb:renesas_usb
	"
source="https://github.com/sunflower2333/linux-firmware-ayaneo/archive/$_commit/linux-firmware-ayaneo-$_commit.tar.gz"
options="!check !strip !archcheck !tracedeps pmb:cross-native"
builddir="$srcdir/linux-firmware-ayaneo-$_commit"

package() {
	install -Dm644 "$builddir"/renesas_usb_fw.mem.zst \
		-t "$pkgdir"/usr/lib/firmware/
	install -Dm644 "$builddir"/qcom/sm8650/ayaneo/ps2/gen70900_zap.mbn.zst \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm8650/ayaneo/ps2/
	install -Dm644 "$builddir"/qcom/sm8650/ayaneo/ps2/adsp* \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm8650/ayaneo/ps2/
	install -Dm644 "$builddir"/qcom/sm8650/ayaneo/ps2/battmgr.jsn.zst \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm8650/ayaneo/ps2/
	install -Dm644 "$builddir"/qcom/sm8650/SM8650-APS2-tplg.bin.zst \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm8650/
	install -Dm644 "$builddir"/qcom/sm8650/ayaneo/ps2/cdsp* \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm8650/ayaneo/ps2/
	install -Dm644 "$builddir"/qcom/vpu/vpu33_p4.mbn.zst \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/qcom/vpu/
	install -Dm644 "$builddir"/ath12k/WCN7850/hw2.0/board-2.bin.zst \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/ath12k/WCN7850/hw2.0/
}

renesas_usb() {
	pkgdesc="Renesas XHCI USB Firmware"

	amove usr/lib/firmware/renesas_usb_fw.mem.zst
}

s2_adreno() {
	pkgdesc="Ayaneo Pocket S2 adreno firmware"

	amove usr/lib/firmware/qcom/sm8650/ayaneo/ps2/gen70900_zap.mbn.zst
}

s2_adsp() {
	pkgdesc="Ayaneo Pocket S2 adsp firmware"

	amove usr/lib/firmware/qcom/sm8650/ayaneo/ps2/adsp*
	amove usr/lib/firmware/qcom/sm8650/ayaneo/ps2/battmgr.jsn.zst
}

s2_tplg() {
	pkgdesc="Ayaneo Pocket S2 Audio Topology"

	amove usr/lib/firmware/qcom/sm8650/SM8650-APS2-tplg.bin.zst
}

s2_cdsp() {
	pkgdesc="Ayaneo Pocket S2 cdsp firmware"

	amove usr/lib/firmware/qcom/sm8650/ayaneo/ps2/cdsp*
}

s2_iris() {
	pkgdesc="Ayaneo Pocket S2 iris firmware"

	amove usr/lib/firmware/postmarketos/qcom/vpu/vpu33_p4.mbn.zst
}

s2_ath12k() {
	pkgdesc="Ayaneo Pocket S2 ath12k firmware"

	amove usr/lib/firmware/postmarketos/ath12k/WCN7850/hw2.0/board-2.bin.zst
}

sha512sums="
0fa6040320ea2493dd31b66b75c247b44030755f7f74df740537b237d77c73f81c4bb01cbd7c9749bcbb8e3a9c37e827b14e64b6ab9da97b3d5b806124657ac2  linux-firmware-ayaneo-17fd5306f1dd33356f0bf85e2781f5c31e98ba0e.tar.gz
"
