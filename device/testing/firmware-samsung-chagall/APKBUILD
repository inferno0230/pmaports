maintainer="Henrik Grimler <henrik@grimler.se>"
pkgname=firmware-samsung-chagall
pkgver=5
pkgrel=0
_commit="3ef6a550213d915356d3fb25cf0560f5d5c87d3d"
pkgdesc="Firmware for Samsung chagallwifi and chagalllte"
url="https://github.com/exynos5420/android_vendor_samsung_chagall-common"
arch="armv7"
license="proprietary"
subpackages="
	$pkgname-downstream
	$pkgname-mainline
	"
_wifi_files="
	bcmdhd_apsta.bin
	bcmdhd_ibss.bin
	bcmdhd_mfg.bin
	bcmdhd_sta.bin
	cred.conf
	nvram_mfg.txt_4354_a1
	nvram_net.txt_4354_a1
	"
for _i in $_wifi_files; do
	source="$source $pkgname-$_commit-$_i::https://github.com/exynos5420/android_vendor_samsung_chagall-common/tree/lineage-18.1/proprietary/etc/wifi/$_i";
done
options="!archcheck !check !spdx !strip !tracedeps pmb:cross-native"

package() {
	for file in $_wifi_files; do
		 install -Dm644 "$srcdir"/"$pkgname"-"$_commit"-"$file" \
			"$pkgdir"/usr/lib/firmware/postmarketos/"$file"
	done

	ln -s bcmdhd_sta.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/bcmdhd_sta.bin_4354_a0
	ln -s bcmdhd_sta.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/bcmdhd_sta.bin_4354_a1
	ln -s nvram_net.txt_4354_a1 \
		"$pkgdir"/usr/lib/firmware/postmarketos/nvram_net.txt_4354_a0

	install -Dm644 "$srcdir"/"$pkgname"-"$_commit"-nvram_net.txt_4354_a1 \
		"$pkgdir"/usr/lib/firmware/brcm/brcmfmac4354-sdio.samsung,chagall-wifi.txt
	ln -s brcmfmac4354-sdio.samsung,chagall-wifi.txt \
		"$pkgdir"/usr/lib/firmware/brcm/brcmfmac4354-sdio.samsung,chagall-lte.txt
}

downstream() {
	pkgdesc="Firmware for Samsung chagall* when using downstream kernel"
	depends="firmware-samsung-exynos5420-downstream"

	# Wifi
	local file
	for file in $_wifi_files; do
		 amove usr/lib/firmware/postmarketos/"$file"
	done

	amove usr/lib/firmware/postmarketos/bcmdhd_sta.bin_4354_a0
	amove usr/lib/firmware/postmarketos/bcmdhd_sta.bin_4354_a1
	amove usr/lib/firmware/postmarketos/nvram_net.txt_4354_a0
}

mainline() {
	pkgdesc="Firmware for Samsung chagall* when using mainline kernel"
	depends="linux-firmware-brcm linux-firmware-s5p-mfc"

	amove usr/lib/firmware/brcm/brcmfmac4354-sdio.samsung,chagall-wifi.txt
	amove usr/lib/firmware/brcm/brcmfmac4354-sdio.samsung,chagall-lte.txt
}

