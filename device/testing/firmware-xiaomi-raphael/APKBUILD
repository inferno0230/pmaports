maintainer=""
pkgname=firmware-xiaomi-raphael
pkgver=20250908
pkgrel=1
_commit="cf9d303adda1cf25dad22cadc192f762f0a06a17"
pkgdesc="Firmware for Xiaomi Mi 9T Pro / Redmi K20 Pro"
arch="aarch64"
_carch="arm64"
subpackages="
	$pkgname-adreno
	$pkgname-adsp
	$pkgname-ath10k
	$pkgname-bluetooth
	$pkgname-camera
	$pkgname-cdsp
	$pkgname-ipa
	$pkgname-modem
	$pkgname-slpi
	$pkgname-touchscreen
	$pkgname-venus
	$pkgname-wlan
	"

url="https://github.com/dabao1955/pmos_firmware_xiaomi_raphael"
license="proprietary"
source="
	https://github.com/dabao1955/pmos_firmware_xiaomi_raphael/archive/$_commit.tar.gz
	30-gpu-firmware.files
	"
options="!check !strip !archcheck !tracedeps pmb:cross-native"
builddir="$srcdir/pmos_firmware_xiaomi_raphael-$_commit"

package() {
	install -Dm644 "$srcdir/30-gpu-firmware.files" \
		-t "$pkgdir"/usr/share/mkinitfs/files/
	install -Dm644 "$builddir"/sm8150/raphael/a6* \
		-t "$pkgdir"/usr/lib/firmware/qcom/
	install -Dm644 "$builddir"/sm8150/raphael/adsp* \
		-t "$pkgdir"/usr/lib/firmware/
	install -Dm644 "$builddir"/sm8150/raphael/wlan/ath10k/board-2.bin \
		-t "$pkgdir"/usr/lib/firmware/ath10k/WCN3990/hw1.0/
	install -Dm644 "$builddir"/sm8150/raphael/wlan/ath10k/firmware-5.bin \
		-t "$pkgdir"/usr/lib/firmware/ath10k/WCN3990/hw1.0/
	install -Dm644 "$builddir"/sm8150/raphael/crnv21.bin \
		-t "$pkgdir"/usr/lib/firmware/qca/
	install -Dm644 "$builddir"/sm8150/raphael/CAMERA_ICP.elf \
		-t "$pkgdir"/usr/lib/firmware/
	install -Dm644 "$builddir"/sm8150/raphael/cdsp* \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm8150/Xiaomi/raphael/
	install -Dm644 "$builddir"/sm8150/raphael/ipa* \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm8150/Xiaomi/raphael/
	install -Dm644 "$builddir"/sm8150/raphael/modem* \
		-t "$pkgdir"/usr/lib/firmware/
	install -Dm644 "$builddir"/sm8150/raphael/slpi* \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm8150/Xiaomi/raphael/
	install -Dm644 "$builddir"/sm8150/raphael/good* \
		-t "$pkgdir"/usr/lib/firmware/
	install -Dm644 "$builddir"/sm8150/raphael/venus.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm8150/Xiaomi/raphael/
	install -Dm644 "$builddir"/sm8150/raphael/wlanmdsp.mbn \
		-t "$pkgdir"/usr/lib/firmware/
}

# Xiaomi raphael boots with secure boot, it can only load signed firmwares.
adreno() {
	pkgdesc="Xiaomi raphael adreno firmware"

	amove usr/lib/firmware/qcom/a6*
}

adsp() {
	pkgdesc="Xiaomi raphael adsp firmware"

	amove usr/lib/firmware/adsp*
}

ath10k() {
	pkgdesc="Xiaomi raphael ath10k firmware"

	amove usr/lib/firmware/ath10k/WCN3990/hw1.0
}

bluetooth() {
	pkgdesc="Xiaomi raphael adsp firmware"

	amove usr/lib/firmware/qca/crnv21.bin
}

camera() {
	pkgdesc="Xiaomi raphael camera firmware"

	amove usr/lib/firmware/CAMERA_ICP.elf
}

cdsp() {
	pkgdesc="Xiaomi raphael cdsp firmware"

	amove usr/lib/firmware/qcom/sm8150/Xiaomi/raphael/cdsp*
}
ipa() {
	pkgdesc="Xiaomi raphael ipa firmware"

	amove usr/lib/firmware/qcom/sm8150/Xiaomi/raphael/ipa*
}

modem() {
	pkgdesc="Xiaomi raphael modem firmware"

	amove usr/lib/firmware/modem*
}

slpi() {
	pkgdesc="Xiaomi raphael slpi firmware"

	amove usr/lib/firmware/qcom/sm8150/Xiaomi/raphael/slpi*
}

touchscreen() {
	pkgdesc="Xiaomi raphael touchscreen firmware"

	amove usr/lib/firmware/good*
}

venus() {
	pkgdesc="Xiaomi raphael venus firmware"

	amove usr/lib/firmware/qcom/sm8150/Xiaomi/raphael/venus.mbn
}

wlan() {
	pkgdesc="Xiaomi raphael wlan firmware"

	amove usr/lib/firmware/wlanmdsp.mbn
}


