pkgname=firmware-google-blueline
pkgver=2
pkgrel=1
_commit="2a15e29129a607ee066b3950c578aab64e9bd82a"
pkgdesc="Firmware for Google Pixel 3 (blueline)"
# Suggested by Caleb as it has working Wifi
url="https://gitlab.com/sdm845-mainline/firmware-google-pixel3"
arch="aarch64"
license="proprietary"
depends="linux-firmware-ath10k linux-firmware-qca linux-firmware-qcom"
source="firmware-google-pixel3-$_commit.tar.gz::https://gitlab.com/sdm845-mainline/firmware-google-pixel3/-/archive/$_commit/firmware-google-pixel3-$_commit.tar.gz
	firmware.files
	"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir/firmware-google-pixel3-$_commit"

package() {
	while IFS="" read -r _i || [ -n "$_i" ]; do
		local _u="${_i/\/usr\/lib/lib}"
		[ ! -d $(dirname "$_i") ] && mkdir -p $(dirname "$pkgdir"/"$_i")
		install -Dm644 "$builddir"/"$_u" "$pkgdir"/"$_i"
	done < "$srcdir/firmware.files"

	# TODO: Do we need these? If so put them into correct paths and into
	# NFC/Secure Element firmware
	#install -Dm644 misc/pn557.bin "$pkgdir/lib/firmware/postmarketos/"
	# Haptic driver firmware
	#install -Dm644 misc/cs40l20.bin "$pkgdir/lib/firmware/postmarketos/"
	# Haptic driver firmware
	#install -Dm644 misc/drv2624.bin "$pkgdir/lib/firmware/postmarketos/"
}

