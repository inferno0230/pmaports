pkgname="sheng-devauth"
_commit=8235e2ab34894178e03e86165318b364aa57b064
pkgver=1.0
pkgdesc="Service used in pair with kernel driver to authenticate Xiaomi Keyboard"
pkgrel=1
arch="aarch64"
url="https://github.com/map220v/sheng_devauth"
license="BSD-3-Clause"
makedepends="
	git
	make
	clang
	linux-headers
"
source="
	https://github.com/map220v/sheng_devauth/archive/$_commit.zip
    	sheng-devauth.service
"

builddir="$srcdir/sheng_devauth-$_commit"

build() {
    cd "$builddir"

    make
}

package() {
    cd "$builddir"

    mkdir -p $pkgdir/usr/bin
    install -m 0755 xiaomi_devauth $pkgdir/usr/bin
    mkdir -p $pkgdir/usr/lib/systemd/system
    install -m 0644 $srcdir/sheng-devauth.service $pkgdir/usr/lib/systemd/system
}

