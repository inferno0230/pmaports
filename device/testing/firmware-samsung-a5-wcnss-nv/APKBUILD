maintainer="Alexey Minnekhanov <alexeymin@postmarketos.org>"
pkgname=firmware-samsung-a5-wcnss-nv
pkgver=2
pkgrel=0
_name="Samsung Galaxy A5 (2015)"
pkgdesc="WiFi/BT firmware for $_name"
url="https://postmarketos.org"
arch="aarch64"
license="proprietary"
options="!check !strip !archcheck !tracedeps pmb:cross-native"
source="$pkgname-WCNSS_qcom_wlan_nv.bin.base64::https://pastebin.com/raw/br6nKv4W"
builddir="$srcdir"
replaces="firmware-samsung-a5lte-wcnss firmware-samsung-a5ulte-wcnss"

_fwdir="/usr/lib/firmware/postmarketos"

build() {
	base64 -d $pkgname-WCNSS_qcom_wlan_nv.bin.base64 > WCNSS_qcom_wlan_nv.bin
}

package() {
	install -Dm644 "$srcdir"/WCNSS_qcom_wlan_nv.bin -t "$pkgdir/$_fwdir"/wlan/prima
}

