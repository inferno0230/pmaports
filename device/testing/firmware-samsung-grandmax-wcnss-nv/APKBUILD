maintainer="Raymond Hackley <wonderfulShrineMaidenOfParadise@postmarketos.org>"
pkgname=firmware-samsung-grandmax-wcnss-nv
pkgver=2
pkgrel=0
_name="Samsung Galaxy Grand Max"
pkgdesc="WiFi/BT firmware for $_name"
url="https://postmarketos.org"
arch="armv7"
license="proprietary"
options="!check !strip !archcheck !tracedeps pmb:cross-native"
source="$pkgname-WCNSS_qcom_wlan_nv.bin.base64::https://pastebin.com/raw/7Kp9JMgq"
builddir="$srcdir"

_fwdir="/usr/lib/firmware/postmarketos"

build() {
	base64 -d $pkgname-WCNSS_qcom_wlan_nv.bin.base64 > WCNSS_qcom_wlan_nv.bin
}

package() {
	install -Dm644 "$srcdir"/WCNSS_qcom_wlan_nv.bin -t "$pkgdir/$_fwdir"/wlan/prima
}

