# Reference: <https://postmarketos.org/devicepkg>
# Contributor: Seshan Ravikumar <seshan@sineware.ca>
# Maintainer: Seshan Ravikumar <seshan@sineware.ca>
pkgname=device-anbernic-rg35xx-sp
pkgdesc="Anbernic RG35XX SP"
pkgver=1
pkgrel=0
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	u-boot-anbernic-rg35xx
	u-boot-tools
	py3-evdev
	firmware-anbernic-rg35xx
	postmarketos-base
"
makedepends="devicepkg-dev"
subpackages="
	$pkgname-kernel-panel_v1:kernel_panel_v1
	$pkgname-kernel-panel_v2:kernel_panel_v2
	$pkgname-systemd
	$pkgname-openrc
"
source="
	deviceinfo
	30-device-firmware.files
	50-rg35xx-kwin.sh
	rg35xx-control-mapper.py
	rg35xx-control-mapper.service
	rg35xx-control-mapper.initd
"

build() {
	devicepkg_build $startdir $pkgname
}

kernel_panel_v1() {
	pkgdesc="RG25XX SP v1 panel DTB"
	depends="linux-anbernic-rg35xx linux-firmware"
	devicepkg_subpackage_kernel $startdir $pkgname $subpkgname
}

kernel_panel_v2() {
	pkgdesc="RG25XX SP v2 panel DTB"
	depends="linux-anbernic-rg35xx linux-firmware"
	devicepkg_subpackage_kernel $startdir $pkgname $subpkgname
}

package() {
	devicepkg_package $startdir $pkgname
	install -Dm644 "$srcdir"/30-device-firmware.files "$pkgdir/usr/share/mkinitfs/files/30-device-firmware.files"
	install -Dm755 "$srcdir"/rg35xx-control-mapper.py \
		"$pkgdir"/usr/bin/rg35xx-control-mapper
	install -Dm644 "$srcdir"/50-rg35xx-kwin.sh \
		"$pkgdir"/etc/profile.d/50-rg35xx-kwin.sh
}

systemd() {
	install_if="$pkgname=$pkgver-r$pkgrel systemd"
	install -Dm644 "$srcdir"/rg35xx-control-mapper.service \
		"$subpkgdir"/usr/lib/systemd/system/rg35xx-control-mapper.service
	mkdir -p "$subpkgdir"/usr/lib/systemd/system/multi-user.target.wants/
	ln -sf /usr/lib/systemd/system/rg35xx-control-mapper.service \
		"$subpkgdir"/usr/lib/systemd/system/multi-user.target.wants/rg35xx-control-mapper.service
	default_systemd
}

openrc() {
	install_if="$pkgname=$pkgver-r$pkgrel openrc"
	install="$subpkgname.post-install"
	install -Dm755 "$srcdir"/rg35xx-control-mapper.initd \
		"$subpkgdir"/etc/init.d/rg35xx-control-mapper
	default_openrc
}

