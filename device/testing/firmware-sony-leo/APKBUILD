maintainer="Luca Weiss <luca@lucaweiss.eu>"
pkgname=firmware-sony-leo
pkgver=2
pkgrel=0
_commit="8d3b4c091b27ee74e973651f709adbfc5740e9fb"
pkgdesc="Firmware for Sony Xperia Z3"
url="https://github.com/FairBlobs/leo-firmware"
arch="armv7"
license="proprietary"
subpackages="
	$pkgname-adsp
	$pkgname-modem
	$pkgname-wifi
	"
source="https://github.com/FairBlobs/leo-firmware/archive/$_commit/leo-firmware-$_commit.tar.gz"
options="!strip !check !archcheck !tracedeps pmb:cross-native"
builddir="$srcdir/leo-firmware-$_commit"

package() {
	for _i in adsp.* mba.* modem.*; do
		install -Dm644 "$_i" \
			-t "$pkgdir"/usr/lib/firmware/postmarketos/
	done

	install -Dm644 brcmfmac4339-sdio.sony,xperia-leo.bin \
		-t "$pkgdir"/usr/lib/firmware/brcm/
	install -Dm644 brcmfmac4339-sdio.txt \
		-t "$pkgdir"/usr/lib/firmware/brcm/
}

adsp() {
	pkgdesc="$pkgdesc (adsp)"

	amove usr/lib/firmware/postmarketos/adsp.*
}

modem() {
	pkgdesc="$pkgdesc (modem)"

	amove usr/lib/firmware/postmarketos/mba.*
	amove usr/lib/firmware/postmarketos/modem.*
}

wifi() {
	pkgdesc="$pkgdesc (wifi)"

	amove usr/lib/firmware/brcm/brcmfmac4339-sdio.sony,xperia-leo.bin
	amove usr/lib/firmware/brcm/brcmfmac4339-sdio.txt
}

sha512sums="
ef6fc9b1dee7ab38c5fcfe1386d670ddeee44a5647f01445acf3fb3d71ef1952354b220d90f09b82524b39b48420a68fe6e7b90937d52d9d18eca5403ba585e5  leo-firmware-8d3b4c091b27ee74e973651f709adbfc5740e9fb.tar.gz
"
