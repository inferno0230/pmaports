maintainer=""
pkgname=firmware-acer-t01-wcnss-nv
pkgver=1
pkgrel=0
pkgdesc="WiFi/BT firmware for Acer Liquid Z330"
url="https://postmarketos.org"
arch="armv7"
license="proprietary"
options="!check !strip !archcheck !tracedeps pmb:cross-native"
source="$pkgname-WCNSS_qcom_wlan_nv.bin.base64::https://pastebin.com/raw/ebRCebX7"
builddir="$srcdir"

_fwdir="/usr/lib/firmware/postmarketos"

build() {
	base64 -d $pkgname-WCNSS_qcom_wlan_nv.bin.base64 > WCNSS_qcom_wlan_nv.bin
}

package() {
	install -Dm644 "$builddir"/WCNSS_qcom_wlan_nv.bin \
		-t "$pkgdir/$_fwdir"/wlan/prima
}

