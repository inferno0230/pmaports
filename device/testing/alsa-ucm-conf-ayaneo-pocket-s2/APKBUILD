provides="alsa-ucm-conf"
provider_priority=1
_commit="5e1cfc6810013182570d6ac8386a58d2fde83b0c"
source="
	$pkgname-$_commit.tar.gz::https://github.com/superna9999/alsa-ucm-conf/archive/$_commit.tar.gz
"
builddir="$srcdir/alsa-ucm-conf-$_commit"
options="!check"

package() {
	# install audio config files
	mkdir -p "$pkgdir"/usr/share/alsa/ucm2
	cp -r "$srcdir/alsa-ucm-conf-$_commit"/ucm2 "$pkgdir"/usr/share/alsa/
}

