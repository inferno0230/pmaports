maintainer=""
pkgname=firmware-oneplus-oneplus3
pkgver=5
pkgrel=0
pkgdesc="Firmware for OnePlus 3"
url="https://gitlab.com/DrGitX/firmware-oneplus3"
arch="aarch64"
license="proprietary"
makedepends="mtools pil-squasher qca-swiss-army-knife"
_files="
