maintainer="Luca Weiss <luca@lucaweiss.eu>"
pkgname=firmware-oneplus-bacon
pkgver=3
pkgrel=0
_commit="a4b0ec447d9ae6d1025fc43b6d7f495298a71b61"
pkgdesc="Firmware for OnePlus One"
url="https://github.com/FairBlobs/bacon-firmware"
arch="armv7"
license="proprietary"
makedepends="pil-squasher"
subpackages="
	$pkgname-adsp
	$pkgname-modem
	$pkgname-wcnss
	"
source="https://github.com/FairBlobs/bacon-firmware/archive/$_commit/bacon-firmware-$_commit.tar.gz"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir/bacon-firmware-$_commit"

build() {
	for i in *.mdt; do
		pil-squasher "$(basename "$i" .mdt)".mbn "$i"
	done
}

package() {
	install -Dm644 "$builddir"/adsp.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/msm8974/oneplus/bacon/
	install -Dm644 "$builddir"/mba.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/msm8974/oneplus/bacon/
	install -Dm644 "$builddir"/modem.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/msm8974/oneplus/bacon/

	mkdir -p "$pkgdir"/usr/lib/firmware/postmarketos/wlan/prima/

	ln -s ../qcom/msm8974/oneplus/bacon/adsp.mbn \
		"$pkgdir"/usr/lib/firmware/postmarketos/adsp.mdt

	install -Dm644 "$builddir"/wcnss.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/msm8974/oneplus/bacon/
	install -Dm644 "$builddir"/WCNSS_qcom_wlan_nv.bin \
		-t "$pkgdir"/usr/lib/firmware/qcom/msm8974/oneplus/bacon/

	ln -s ../qcom/msm8974/oneplus/bacon/wcnss.mbn \
		"$pkgdir"/usr/lib/firmware/postmarketos/wcnss.mdt
	ln -s ../../../qcom/msm8974/oneplus/bacon/WCNSS_qcom_wlan_nv.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/wlan/prima/WCNSS_qcom_wlan_nv.bin
	}

adsp() {
	pkgdesc="OnePlus One adsp firmware"

	amove usr/lib/firmware/qcom/msm8974/oneplus/bacon/adsp.mbn
	amove usr/lib/firmware/postmarketos/adsp.mdt
}

modem() {
	pkgdesc="OnePlus One modem firmware"

	amove usr/lib/firmware/qcom/msm8974/oneplus/bacon/mba.mbn
	amove usr/lib/firmware/qcom/msm8974/oneplus/bacon/modem.mbn
}

wcnss() {
	pkgdesc="OnePlus One wcnss firmware"

	amove usr/lib/firmware/qcom/msm8974/oneplus/bacon/wcnss.mbn
	amove usr/lib/firmware/qcom/msm8974/oneplus/bacon/WCNSS_qcom_wlan_nv.bin
	amove usr/lib/firmware/postmarketos/wcnss.mdt
	amove usr/lib/firmware/postmarketos/wlan/prima/WCNSS_qcom_wlan_nv.bin
}

sha512sums="
f0236721ba435244dd7581f70b7b413888c3faeaaca7185c87a85ae2d82ea88c73231d753a59053ab53b3fa8529b7d9d52017334546f9ab26a1c0d38767a7b40  bacon-firmware-a4b0ec447d9ae6d1025fc43b6d7f495298a71b61.tar.gz
"
