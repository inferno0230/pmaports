maintainer=""
pkgname=firmware-huawei-y635-wcnss-nv
pkgver=1
pkgrel=0
pkgdesc="WiFi/BT firmware for Huawei Y635"
url="https://postmarketos.org"
arch="aarch64"
license="proprietary"
source="$pkgname-WCNSS_qcom_wlan_nv.bin.base64::https://pastebin.com/raw/yYNgH3PW"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir"

build() {
	base64 -d $pkgname-WCNSS_qcom_wlan_nv.bin.base64 > WCNSS_qcom_wlan_nv.bin
}

package() {
	install -Dm644 "$builddir"/WCNSS_qcom_wlan_nv.bin \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/wlan/prima/
}

