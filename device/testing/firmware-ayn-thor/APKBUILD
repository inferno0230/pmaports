maintainer="angelthorns <angelthorns@kohlroulade.lgbt>"
pkgname=firmware-ayn-thor
pkgver=1
pkgrel=0
pkgdesc="Firmware for the AYN Thor"
url="https://github.com/angelthorns/firmware-ayn-thor"
arch="aarch64"
license="prorietary"
options="!check !strip !archcheck !tracedeps pmb:cross-native"
_commit="f602c0f0f38ff41cbb7bbe13c307de7930557aad"
source="$pkgname-$_commit.tar.gz::$url/archive/$_commit/$pkgname-$_commit.tar.gz"


builddir="$srcdir/$pkgname-$_commit"

package() {
	mkdir -p "$pkgdir"
	find . -type f -exec install -Dm644 {} "$pkgdir"/{} \;
}

