# Contributor: Kevin Widjaja <kevinwidjaja_dev@proton.me>
maintainer="Kevin Widjaja <kevinwidjaja_dev@proton.me>"
pkgname=firmware-anbernic-rgxxxx
pkgver=1
pkgrel=0
pkgdesc="Firmware for Anbernic RGXXXX series devices"
url="https://github.com/kevinwidjaja21/knulli-extra_firmwares"
_repository="knulli-extra_firmwares"
_commit="0e1acd9e3f4a293d3f498c79780879805d22660d"
arch="aarch64"
license="proprietary"
options="!check !strip !archcheck !spdx !tracedeps pmb:cross-native"

source="
	$_repository-$_commit.tar.gz::https://github.com/kevinwidjaja21/$_repository/archive/$_commit.tar.gz
	panel.files
"

package() {
	cd "$srcdir/$_repository-$_commit/"
	while IFS="" read -r _i || [ -n "$_i" ]; do
		_filename=$(basename "$_i")
		_destdir="$pkgdir/lib/firmware/panels"
		[ ! -d "$_destdir" ] && mkdir -p "$_destdir"
		install -Dm644 "$_i" "$_destdir/$_filename"
	done < "$srcdir/panel.files"
}

