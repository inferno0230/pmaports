maintainer="binarycraft007 <keep.it.sns@gmail.com>"
pkgname=firmware-asus-s5507q
pkgver=4
pkgrel=0
_commit="2f3f3b5cc679f88a6f672490778e19016e51a70b"
pkgdesc="Firmware files for ASUS Vivobook S 15"
url="https://github.com/binarycraft007/firmware-asus-s5507q"
arch="aarch64"
license="proprietary"
# TODO: Replace with a dependency on firmware-qcom-adreno-gen70500 (which is not .zst compressed though)
depends="
	linux-firmware-qcom
	linux-firmware-qca
	linux-firmware-ath12k
"
subpackages="
	$pkgname-common
	$pkgname-dpu
"
source="$pkgname-$_commit.tar.gz::https://github.com/binarycraft007/firmware-asus-s5507q/archive/$_commit.tar.gz
	dpu.files
	common.files
"
options="!check !strip !archcheck !spdx !tracedeps pmb:cross-native"
builddir="$srcdir/firmware-asus-s5507q-$_commit"

package() {
	mkdir -p "$pkgdir"
}

common() {
	while IFS="" read -r _i || [ -n "$_i" ]; do
		local _u="${_i/usr\/lib/\/lib}"
		[ ! -d $(dirname $_i) ] && mkdir -p $(dirname "$subpkgdir"/$_i)
		install -Dm644 "$builddir/$_u" "$subpkgdir/$_i"
	done < "$srcdir/common.files"

	install -Dm644 "$srcdir/common.files" \
		-t "$subpkgdir"/usr/share/mkinitfs/files/
}

dpu() {
	install -Dm644 "$srcdir/dpu.files" \
		-t "$subpkgdir"/usr/share/mkinitfs/files/
}

sha512sums="
