maintainer=""
pkgname=firmware-samsung-a6lte
pkgver=4
pkgrel=0
pkgdesc="Firmware files for Samsung Galaxy A6 (2018)"
arch="aarch64"
url="https://dumps.tadiphone.dev/dumps/samsung/a6lte"
license="proprietary"
depends="linux-firmware-brcm"
makedepends="
	linux-firmware-brcm
	zstd
	"
source="nvram.txt_c5::https://dumps.tadiphone.dev/dumps/samsung/a6lte/-/raw/a6ltejx-user-9-PPR1.180610.011-A600FJXS5BSL1-release-keys/vendor/etc/wifi/nvram.txt_c5"
options="!archcheck !check !spdx !strip !tracedeps pmb:cross-native"

package() {
	mkdir -p "$pkgdir"/usr/lib/firmware/postmarketos/wifi
	unzstd < /usr/lib/firmware/brcm/brcmfmac43456-sdio.bin.zst > "$pkgdir"/usr/lib/firmware/postmarketos/wifi/bcmdhd_apsta.bin_c5
	unzstd < /usr/lib/firmware/brcm/brcmfmac43456-sdio.clm_blob.zst > "$pkgdir"/usr/lib/firmware/postmarketos/wifi/bcmdhd_clm.blob
	ln -s bcmdhd_apsta.bin_c5 \
		"$pkgdir"/usr/lib/firmware/postmarketos/wifi/bcmdhd_apsta.bin_c5_blob
	ln -s bcmdhd_apsta.bin_c5 \
		"$pkgdir"/usr/lib/firmware/postmarketos/wifi/bcmdhd_mfg.bin_c5
	ln -s bcmdhd_apsta.bin_c5 \
		"$pkgdir"/usr/lib/firmware/postmarketos/wifi/bcmdhd_mfg.bin_c5_blob
	ln -s bcmdhd_apsta.bin_c5 \
		"$pkgdir"/usr/lib/firmware/postmarketos/wifi/bcmdhd_sta.bin_c5
	ln -s bcmdhd_apsta.bin_c5 \
		"$pkgdir"/usr/lib/firmware/postmarketos/wifi/bcmdhd_sta.bin_c5_blob
	install -Dm644 "$srcdir"/nvram.txt_c5 \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/wifi/
}

sha512sums="
b9e1e695cb01497400c0f0c3ccd0e7815a10258775bd89edda3ce89926cb1f9e4172b068553bce7120766ff673e265a9cbe54f94cca0f72496a04a216f4c9a0f  nvram.txt_c5
"
