maintainer="Luca Weiss <luca@lucaweiss.eu>"
pkgname=firmware-htc-memul
pkgver=2
pkgrel=0
_fw_commit="d89bafbb77277ccc600a34a2b7533be5bf6b278f"
_dt_commit="38db7981457b45d5e834d05bfff49afbea01c25e"
pkgdesc="Firmware for HTC One Mini 2"
subpackages="
	$pkgname-adsp
	$pkgname-modem
	$pkgname-wcnss
	"
url="https://github.com/FairBlobs/memul-firmware"
arch="armv7"
license="proprietary"
makedepends="pil-squasher"
source="$pkgname-$_fw_commit.tar.gz::https://github.com/FairBlobs/memul-firmware/archive/$_fw_commit.tar.gz
	$pkgname-WCNSS_cfg.dat::https://raw.githubusercontent.com/nightcore500/android_device_htc_memul/$_dt_commit/wifi/WCNSS_cfg.dat
	$pkgname-WCNSS_qcom_cfg.ini::https://raw.githubusercontent.com/nightcore500/android_device_htc_memul/$_dt_commit/wifi/WCNSS_qcom_cfg.ini
	$pkgname-WCNSS_qcom_wlan_nv.bin::https://raw.githubusercontent.com/nightcore500/android_device_htc_memul/$_dt_commit/wifi/WCNSS_qcom_wlan_nv.bin
	"
options="!check !strip !archcheck !tracedeps pmb:cross-native"

builddir="$srcdir/memul-firmware-$_fw_commit"

build() {
	for i in adsp.mdt mba.mdt modem.mdt; do
		pil-squasher "$(basename "$i" .mdt)".mbn "$i"
	done
}

package() {
	install -Dm644 "$builddir"/adsp.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/msm8926/memul/
	install -Dm644 "$builddir"/mba.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/msm8926/memul/
	install -Dm644 "$builddir"/modem.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/msm8926/memul/

	# Squashing wcnss firmware leads to incomplete .mbn, so keep installing
	# the original .mdt + .b0* files
	install -Dm644 "$builddir"/wcnss.* \
		-t "$pkgdir"/usr/lib/firmware/qcom/msm8926/memul/
	install -Dm644 "$srcdir"/"$pkgname"-WCNSS_cfg.dat \
		"$pkgdir"/usr/lib/firmware/postmarketos/wlan/prima/WCNSS_cfg.dat
	install -Dm644 "$srcdir"/"$pkgname"-WCNSS_qcom_cfg.ini \
		"$pkgdir"/usr/lib/firmware/postmarketos/wlan/prima/WCNSS_qcom_cfg.ini
	install -Dm644 "$srcdir"/"$pkgname"-WCNSS_qcom_wlan_nv.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/wlan/prima/WCNSS_qcom_wlan_nv.bin
}

adsp() {
	pkgdesc="HTC One Mini 2 - ADSP firmware"

	amove usr/lib/firmware/qcom/msm8926/memul/adsp.mbn
}

modem() {
	pkgdesc="HTC One Mini 2 - Modem firmware"

	amove usr/lib/firmware/qcom/msm8926/memul/mba.mbn
	amove usr/lib/firmware/qcom/msm8926/memul/modem.mbn
}

wcnss() {
	pkgdesc="HTC One Mini 2 - WCNSS firmware"

	amove usr/lib/firmware/qcom/msm8926/memul/wcnss.*
	amove usr/lib/firmware/postmarketos/wlan/prima/WCNSS_cfg.dat
	amove usr/lib/firmware/postmarketos/wlan/prima/WCNSS_qcom_cfg.ini
	amove usr/lib/firmware/postmarketos/wlan/prima/WCNSS_qcom_wlan_nv.bin
}

sha512sums="
