maintainer=""
pkgname=firmware-lenovo-q706f
pkgver=20240726
pkgrel=3
_commit="1be73450f1aaa6896c59fc1768a4fc98abe7cbda"
pkgdesc="Firmware for Lenovo Xiaoxin Pad Pro 12.6 (Lenovo Tab P12 Pro)"
url="https://github.com/silime/lenovo-sm8250-q706f-firmware"
arch="aarch64"
license="proprietary"
subpackages="
	$pkgname-adreno
	$pkgname-adsp
	$pkgname-cdsp
	$pkgname-cirrus
	$pkgname-hexagonfs
	$pkgname-slpi
	$pkgname-venus
	"
source="$pkgname.tar.gz::https://github.com/silime/lenovo-sm8250-q706f-firmware/archive/$_commit.tar.gz"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir/lenovo-sm8250-q706f-firmware-$_commit"

package() {
	install -Dm644 "$builddir"/sm8250/q706f/a650_zap.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm8250/q706f/
	install -Dm644 "$builddir"/sm8250/q706f/adsp* \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm8250/q706f/
	install -Dm644 "$builddir"/sm8250/q706f/cdsp* \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm8250/q706f/
	install -Dm644 "$builddir"/cirrus/cs35l45* \
		-t "$pkgdir"/usr/lib/firmware/cirrus/
	install -Dm644 "$builddir"/sm8250/q706f/slpi* \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm8250/q706f/
	install -Dm644 "$builddir"/sm8250/q706f/venus.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm8250/q706f/

	mkdir -p "$pkgdir"/usr/share/qcom/sm8250/Lenovo
	cp -r "$builddir"/hexagonfs/ \
		"$pkgdir"/usr/share/qcom/sm8250/Lenovo/q706f/
	# Remove files that we don't need - for now
	rm -r "$pkgdir"/usr/share/qcom/sm8250/Lenovo/q706f/acdb/
	rm -r "$pkgdir"/usr/share/qcom/sm8250/Lenovo/q706f/dsp/
	# Used cp to move subdirectories, so set perms manually
	find "$pkgdir"/usr/share/qcom/sm8250/Lenovo/q706f/ \
		-type f -exec chmod 0644 {} \;
}

# lenovo q706f boots with secure boot, it can only load signed firmwares.
adreno() {
	pkgdesc="Lenovo q706f adreno firmware"
	depends="firmware-qcom-adreno-a650"

	amove usr/lib/firmware/qcom/sm8250/q706f/a650_zap.mbn
}

adsp() {
	pkgdesc="Lenovo q706f adsp firmware"

	amove usr/lib/firmware/qcom/sm8250/q706f/adsp*
}

cdsp() {
	pkgdesc="Lenovo q706f cdsp firmware"

	amove usr/lib/firmware/qcom/sm8250/q706f/cdsp*
}

cirrus() {
	pkgdesc="Lenovo q706f cirrus firmware"

	amove usr/lib/firmware/cirrus/cs35l45*
}

hexagonfs() {
	pkgdesc="Lenovo q706f hexagonfs files"

	amove usr/share/qcom/sm8250/Lenovo/q706f
}

slpi() {
	pkgdesc="Lenovo q706f slpi firmware"

	amove usr/lib/firmware/qcom/sm8250/q706f/slpi*
}

venus() {
	pkgdesc="Lenovo q706f venus firmware"

	amove usr/lib/firmware/qcom/sm8250/q706f/venus.mbn
}

sha512sums="
