maintainer="Alicja Michalska <alicja.michalska@9elements.com>"
pkgname=firmware-lynx-r1
pkgver=20250704
pkgrel=1
_commit="5ee6f8cf08d50500123063e19744b84f239740b7"
pkgdesc="Firmware for Lynx R1"
subpackages="
	$pkgname-adreno
	$pkgname-adsp
	$pkgname-cdsp
	$pkgname-cvpss
	$pkgname-fingerpr
	$pkgname-npu
	$pkgname-slpi
	$pkgname-venus
	"
url="https://github.com/ellyq/lynx-firmware-mainline"
arch="aarch64"
license="proprietary"
source="https://github.com/ellyq/lynx-firmware-mainline/archive/$_commit/lynx-firmware-mainline-$_commit.tar.gz"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir/lynx-firmware-mainline-$_commit"

package() {
	install -Dm644 "$builddir"/a650_zap.mbn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/
	install -Dm644 "$builddir"/adsp*.mbn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/
	install -Dm644 "$builddir"/adsp*.jsn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/
	install -Dm644 "$builddir"/cdsp*.mbn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/
	install -Dm644 "$builddir"/cdsp*.jsn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/
	install -Dm644 "$builddir"/cvpss.mbn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/
	install -Dm644 "$builddir"/fingerpr.mbn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/
	install -Dm644 "$builddir"/npu.mbn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/
	install -Dm644 "$builddir"/slpi.mbn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/
	install -Dm644 "$builddir"/venus.mbn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/
}

# Adreno GPU
adreno() {
	pkgdesc="Adreno 650 FW"

	amove usr/lib/firmware/postmarketos/a650_zap.mbn
}

# Audio DSP
adsp() {
	pkgdesc="Lynx R1 ADSP FW"

	amove usr/lib/firmware/postmarketos/adsp*.mbn
	amove usr/lib/firmware/postmarketos/adsp*.jsn
}

# Compute DSP
cdsp() {
	pkgdesc="Lynx R1 CDSP FW"

	amove usr/lib/firmware/postmarketos/cdsp*.mbn
	amove usr/lib/firmware/postmarketos/cdsp*.jsn
}

# Camera V... Position? Not sure.
cvpss() {
	pkgdesc="Lynx R1 CVPSS FW"

	amove usr/lib/firmware/postmarketos/cvpss.mbn
}

# Finger tracking? Wincyj blobow, filesystem wytrzyma
fingerpr() {
	pkgdesc="Lynx R1 FingerPR FW"

	amove usr/lib/firmware/postmarketos/fingerpr.mbn
}

# Neural Processing Unit
npu() {
	pkgdesc="Lynx R1 NPU FW"

	amove usr/lib/firmware/postmarketos/npu.mbn
}

# Sensor Low Power Island
slpi() {
	pkgdesc="Lynx R1 SLPI FW"

	amove usr/lib/firmware/postmarketos/slpi.mbn
}

# Video Processing Unit
venus() {
	pkgdesc="Lynx R1 Venus FW"

	amove usr/lib/firmware/postmarketos/venus.mbn
}

