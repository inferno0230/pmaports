maintainer=""
pkgname=soc-qcom-msm8909
pkgdesc="Common package for Qualcomm MSM8909 devices"
pkgver=1
pkgrel=4
url="https://postmarketos.org"
license="GPL-3.0-or-later"
arch="armv7 aarch64"
options="!check !archcheck"
depends="soc-qcom-msm8916"
install="$pkgname-modem-openrc.post-install"
subpackages="
	$pkgname-modem
	$pkgname-modem-openrc:modem_openrc
	$pkgname-modem-systemd:modem_systemd
"

source="
	msm8909-modem-wwan-port.initd
	msm8909-modem-wwan-port.service
	80-msm8909-modem-wwan-port.preset
"

package() {
	mkdir -p "$pkgdir"
}

modem() {
	pkgdesc="Modem support for Qualcomm MSM8909 devices"
	install_if="soc-qcom-msm8909 soc-qcom-msm8916-rproc"
	depends="qmi-utils"
	mkdir -p "$subpkgdir"
}

modem_openrc() {
	install_if="$pkgname-modem=$pkgver-r$pkgrel openrc"

	install -D -m755 "$srcdir"/msm8909-modem-wwan-port.initd \
		"$subpkgdir"/etc/init.d/msm8909-modem-wwan-port
}

modem_systemd() {
	install_if="$pkgname-modem=$pkgver-r$pkgrel systemd"

	install -D -m644 "$srcdir"/msm8909-modem-wwan-port.service \
		"$subpkgdir"/usr/lib/systemd/system/msm8909-modem-wwan-port.service
	install -D -m644 "$srcdir"/80-msm8909-modem-wwan-port.preset \
		"$subpkgdir"/usr/lib/systemd/system-preset/80-msm8909-modem-wwan-port.preset
}

