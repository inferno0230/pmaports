maintainer="Aster Boese <asterboese@mailbox.org>"
pkgname=firmware-apple-idevice
pkgver=0_git20260612
pkgrel=0
_commit="1241d49aab85ca2320bf58655b9426a021214ed0"
pkgdesc="Firmware for Apple iDevices"
url="https://github.com/Fruit-Firmware/Fruit-Firmware"
arch="aarch64"
license="proprietary"
source="https://github.com/Fruit-Firmware/Fruit-Firmware/archive/$_commit.tar.gz"
options="!archcheck !check !spdx !strip !tracedeps pmb:cross-native"
builddir="$srcdir/Fruit-Firmware-$_commit"

package() {
	mkdir -p "$pkgdir"/usr/lib/firmware/apple

	for i in "$builddir"/firmware/apple/*; do
		install -Dm644 "$i" \
			"$pkgdir"/usr/lib/firmware/apple/"$(basename "$i")"
	done
}

