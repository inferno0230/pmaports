# Reference: <https://postmarketos.org/devicepkg>
maintainer="sleirsgoevy <sleirsgoevy@gmail.com>"
pkgname=device-sony-ps5
pkgdesc="Sony PlayStation 5"
pkgver=1
pkgrel=0
url="https://postmarketos.org"
license="MIT"
arch="x86_64"
options="!check !archcheck"
depends="
	linux-sony-ps5
	postmarketos-base
"
makedepends="devicepkg-dev"
source="
	boot-PS5-Linux-path-override.txt
	deviceinfo
	modules-initfs
	usr-lib-kernel-cmdline.d-99-ps5.conf
	usr-share-boot-deploy-hooks-99-ps5.sh
	usr-share-mkinitfs-files-extra-99-ps5-amdgpu-firmware.txt
"
subpackages="$pkgname-nonfree-firmware:nonfree_firmware"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname

	install -Dm755 "$srcdir/usr-share-boot-deploy-hooks-99-ps5.sh" "$pkgdir/usr/share/boot-deploy/hooks/99-ps5.sh"
	install -Dm644 "$srcdir/usr-lib-kernel-cmdline.d-99-ps5.conf" "$pkgdir/usr/lib/kernel-cmdline.d/99-ps5.conf"
	install -Dm644 "$srcdir/boot-PS5-Linux-path-override.txt" "$pkgdir/boot/PS5/Linux/path-override.txt"
}

nonfree_firmware() {
	depends="linux-firmware-amdgpu"

	install -Dm644 "$srcdir/usr-share-mkinitfs-files-extra-99-ps5-amdgpu-firmware.txt" "$subpkgdir/usr/share/mkinitfs/files-extra/99-ps5-amdgpu-firmware.txt"
}

