maintainer="Luca Weiss <luca@lucaweiss.eu>"
pkgname=firmware-lg-hammerhead
pkgver=2
pkgrel=0
_modem_commit="d0565ebb2033bbd267b8be698373f075c9a82cd5"
pkgdesc="Firmware for LG hammerhead (Nexus 5)"
url="https://developers.google.com/android/drivers#hammerheadm4b30z"
arch="armv7"
license="proprietary"
subpackages="
	$pkgname-adsp
	$pkgname-bluetooth
	$pkgname-modem
	"
source="https://gitlab.com/JuniorJPDJ/hammerhead-modem/-/archive/$_modem_commit/hammerhead-modem-$_modem_commit.tar.gz
	https://dl.google.com/dl/android/aosp/qcom-hammerhead-m4b30z-d6c0fe26.tgz
	https://dl.google.com/dl/android/aosp/broadcom-hammerhead-m4b30z-21cf8433.tgz
	brcmfmac4339-sdio.txt
	"
options="!archcheck !check !strip !tracedeps pmb:cross-native"

unpack() {
	default_unpack

	mkdir -p "$srcdir/qcom" "$srcdir/broadcom"
	tail -n +315 "$srcdir/extract-qcom-hammerhead.sh" | tar -C "$srcdir/qcom" -zx
	tail -n +276 "$srcdir/extract-broadcom-hammerhead.sh" | tar -C "$srcdir/broadcom" -zx
}

package() {
	install -Dm644 "$srcdir"/brcmfmac4339-sdio.txt \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/brcm/
	install -Dm644 "$srcdir/broadcom/vendor/broadcom/hammerhead/proprietary/bcm4335c0.hcd" \
		"$pkgdir"/usr/lib/firmware/postmarketos/brcm/BCM4335C0.hcd

	for _i in "$srcdir"/hammerhead-modem-"$_modem_commit"/image/*; do
		install -Dm644 "$_i" \
			-t "$pkgdir"/usr/lib/firmware/postmarketos/
	done

	for _i in "$srcdir"/qcom/vendor/qcom/hammerhead/proprietary/adsp.*; do
		install -Dm644 "$_i" \
			-t "$pkgdir"/usr/lib/firmware/postmarketos/
	done
}

adsp() {
	pkgdesc="LG Nexus 5 adsp firmware"

	amove usr/lib/firmware/postmarketos/adsp*
}

bluetooth() {
	pkgdesc="LG Nexus 5 Bluetooth firmware"

	amove usr/lib/firmware/postmarketos/brcm/BCM4335C0.hcd
}

modem() {
	pkgdesc="LG Nexus 5 modem firmware"

	amove usr/lib/firmware/postmarketos/mba.*
	amove usr/lib/firmware/postmarketos/modem.*
}

