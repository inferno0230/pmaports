maintainer=""
pkgname=firmware-huawei-kiwi
pkgver=3
pkgrel=0
_commit="2a4db2a026568abfaf342211e9f3d63ac044a9d9"
pkgdesc="Firmware for Huawei Honor 5X / GR5 (2016)"
url="https://git.sr.ht/~bo41/firmware-huawei-kiwi"
arch="aarch64"
license="proprietary"
makedepends="pil-squasher"
subpackages="$pkgname-venus $pkgname-wcnss-nv:wcnss_nv"
source="$pkgname-$_commit.tar.gz::$url/archive/$_commit.tar.gz"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir/$pkgname-$_commit"

_fwdir="/usr/lib/firmware/postmarketos"

build() {
	# venus.mbn exists already but seems a bit different
	pil-squasher venus2.mbn venus.mdt
}

package() {
	# Linux detects squashed (.mbn) vs non-squashed (.mdt + .b*) based on
	# file contents, so it is fine to link venus.mbn to venus.mdt
	# Older kernels look for venus.mdt, newer ones directly for venus.mbn
	install -Dm644 "$builddir"/venus2.mbn \
		"$pkgdir/$_fwdir"/qcom/venus-1.8/venus.mbn
	ln -s venus.mbn \
		"$pkgdir/$_fwdir"/qcom/venus-1.8/venus.mdt
	install -Dm644 "$builddir"/WCNSS_qcom_wlan_nv.bin \
		-t "$pkgdir/$_fwdir"/wlan/prima
}

venus() {
	pkgdesc="$pkgdesc (video firmware)"

	amove usr/lib/firmware/postmarketos/qcom/venus-1.8/venus.mbn
	amove usr/lib/firmware/postmarketos/qcom/venus-1.8/venus.mdt
}

wcnss_nv() {
	pkgdesc="$pkgdesc (WiFi/BT firmware configuration)"

	amove usr/lib/firmware/postmarketos/wlan/prima/WCNSS_qcom_wlan_nv.bin
}

sha512sums="
a5aa89b37ff2e6ac5e8808cf6be97d7850e0d52c7654abf6c044de54c42c737a0b4242c439856dd56c4c5f2721b79941b604ac5a42506aec8020283c446301d4  firmware-huawei-kiwi-2a4db2a026568abfaf342211e9f3d63ac044a9d9.tar.gz
"
