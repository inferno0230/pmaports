arch="aarch64"
depends="
	linux-fydetab-duo
	postmarketos-base
	u-boot-fydetab-duo
"
makedepends="
	devicepkg-dev
"
source="
	deviceinfo
	modules-initfs
	99-debug.conf
"
options="!check !archcheck"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname
	install -Dm 644 99-debug.conf "$pkgdir"/etc/kernel-cmdline.d/99-debug.conf
}

