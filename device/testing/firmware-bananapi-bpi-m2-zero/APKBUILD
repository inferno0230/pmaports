maintainer=""
pkgname=firmware-bananapi-bpi-m2-zero
pkgver=1
pkgrel=0
_commit="a4846b40bc92b6d12e83143353455b2e79bf385e"
pkgdesc="Firmware for the Banana Pi M2 Zero"
url="https://github.com/BPI-SINOVOIP/BPI_WiFi_Firmware"
arch="armv7"
license="proprietary"
source="$pkgname-$pkgver.tar.gz::https://github.com/user0-07161/bananapi-m2-zero-wifi/archive/$_commit.tar.gz"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir/bananapi-m2-zero-wifi-$_commit"

package() {
	# _directories="ap6210 ap6212 brcm"
	for _i in ap6210 ap6212 brcm; do
		_files=$(find "$_i"/ -exec basename {} \;)
		for _file in $_files; do
			if [ "$_i" != "$file" ]; then
				# true is needed to ignore errors when install tries to install the root directory.
				install -D -m644 "$_i"/"$_file" \
					"$pkgdir"/usr/lib/firmware/"$_i"/"$_file" \
					|| true
			fi
		done
	done
}

