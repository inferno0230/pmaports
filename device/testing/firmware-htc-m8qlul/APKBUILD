maintainer="Newbyte <newbie13xd@gmail.com>"
pkgname=firmware-htc-m8qlul
pkgver=2
pkgrel=0
_commit=079fc1c4faec2555153b905b7be80ff2b86804f2
pkgdesc="Firmware for HTC One M8s"
url="https://github.com/evokelektrique/firmware-htc-m8qlul"
arch="aarch64"
license="proprietary"
subpackages="$pkgname-modem $pkgname-venus $pkgname-wcnss"
source="https://github.com/evokelektrique/firmware-htc-m8qlul/archive/$_commit.tar.gz"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir/$pkgname-$_commit"

_fwdir="/usr/lib/firmware/postmarketos"

package() {
	install -Dm644 "$builddir"/MBA.MBN \
		-t "$pkgdir/$_fwdir"/
	install -Dm644 "$builddir"/MODEM.* \
		-t "$pkgdir/$_fwdir"/
	install -Dm644 "$builddir"/venus.* \
		-t "$pkgdir/$_fwdir"/qcom/venus-1.8
	install -Dm644 "$builddir"/wcnss.* \
		-t "$pkgdir/$_fwdir"/

	_files="WCNSS_cfg.dat WCNSS_qcom_cfg.ini WCNSS_qcom_wlan_nv.bin"
	for file in $_files; do
		install -Dm644 "$builddir"/wlan/prima/"$file" \
			-t "$pkgdir/$_fwdir"/wlan/prima/
	done
}

modem() {
	pkgdesc="HTC One M8s modem firmware"

	amove usr/lib/firmware/postmarketos/MBA.MBN
	amove usr/lib/firmware/postmarketos/MODEM.*
}

venus() {
	pkgdesc="HTC One M8s video firmware"

	amove usr/lib/firmware/postmarketos/qcom/venus-1.8
}

wcnss() {
	pkgdesc="HTC One M8s WiFi/Bluetooth firmware"

	amove usr/lib/firmware/postmarketos/wcnss.*
	for file in $_files; do
		amove usr/lib/firmware/postmarketos/wlan/prima/"$file"
	done
}


sha512sums="
744f8e787c89b8d0f8eed52956992961233236adae05ee541a01866006a7407d63b605991fa8935f16054dfd671e5b9bf94660310b70d3e1bc610f9563e05bc4  079fc1c4faec2555153b905b7be80ff2b86804f2.tar.gz
"
