maintainer=""
pkgname=firmware-nokia-sparkler
pkgver=20.00.17.01
pkgrel=1
pkgdesc="Firmware for Nokia 8000 4G"
url="https://storage.abscue.de/private/zImage/$pkgname-$pkgver"
arch="armv7"
license="proprietary"
subpackages="$pkgname-venus:venus_package $pkgname-wcnss-nv:wcnss_nv_package"
source="https://storage.abscue.de/private/zImage/$pkgname-$pkgver/$pkgname.tar.gz"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir/$pkgname"

package() {
	# venus.mbn already exists and doesn't differ from the file produced
	# by pil-squasher
	install -Dm644 venus.mbn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/qcom/venus-3.0/

	install -Dm644 wlan/prima/WCNSS_qcom_wlan_nv.bin \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/wlan/prima/
}

venus_package() {
	pkgdesc="Nokia 8000 4G video encoder/decoder firmware"

	amove usr/lib/firmware/postmarketos/qcom/venus-3.0/venus.mbn
}

wcnss_nv_package() {
	pkgdesc="Nokia 8000 4G WiFi/BT firmware configuration"

	amove usr/lib/firmware/postmarketos/wlan/prima/WCNSS_qcom_wlan_nv.bin
}

sha512sums="
550af8ef37f2c2a3fec5a7fded1dc11f066391195eadcbc32ff19e063f4ae0c529ff5a1191ade1a57545f681e1bdf5fc1c6214061aab7a5b5d37fef7608a59b4  firmware-nokia-sparkler.tar.gz
"
