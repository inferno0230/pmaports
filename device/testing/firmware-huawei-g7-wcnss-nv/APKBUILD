maintainer=""
pkgname=firmware-huawei-g7-wcnss-nv
pkgver=1
pkgrel=0
pkgdesc="WiFi/BT firmware for Huawei Ascend G7"
url="https://postmarketos.org"
arch="aarch64"
license="proprietary"
source="$pkgname-WCNSS_qcom_wlan_nv.bin.base64::https://pastebin.com/raw/UmTSZBW7"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir"

_fwdir="/usr/lib/firmware/postmarketos"

build() {
	base64 -d $pkgname-WCNSS_qcom_wlan_nv.bin.base64 > WCNSS_qcom_wlan_nv.bin
}

package() {
	install -Dm644 "$srcdir"/WCNSS_qcom_wlan_nv.bin \
		-t "$pkgdir/$_fwdir"/wlan/prima/
}

