# Reference: <https://postmarketos.org/deviceinfo>
# Please use double quotes only. You can source this file in shell
# scripts.

deviceinfo_format_version="0"
deviceinfo_name="MediaTek MT6789/MT8781-based device"
deviceinfo_codename="mediatek-g99"
deviceinfo_manufacturer="MediaTek"
deviceinfo_year="2022"
deviceinfo_arch="aarch64"

# Device related
deviceinfo_drm="true"
deviceinfo_external_storage="true"
deviceinfo_rootfs_image_sector_size="4096"

# We're using U-Boot as BL33, as LK with header v4 was too annoying to work with.
# All MT6789/MT8781 devices should be able to boot with U-Boot's EFI implementation.
deviceinfo_boot_filesystem="fat32"
deviceinfo_flash_method="mtkclient"
deviceinfo_flash_pagesize="4096"
deviceinfo_flash_sparse="true"
