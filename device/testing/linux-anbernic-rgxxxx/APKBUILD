maintainer="Kevin Widjaja <kevinwidjaja_dev@proton.me>"
pkgname=linux-anbernic-rgxxxx
pkgver=7.0.10
pkgrel=0
pkgdesc="Close-to-mainline kernel fork for Anbernic RGXXXX H700 devices"
arch="aarch64"
_carch="arm64"
_flavor="anbernic-rgxxxx"
url="https://kernel.org"
license="GPL-2.0-only"
options="!strip !check !tracedeps pmb:cross-native"
makedepends="
	bash
	bc
	bison
	clang
	devicepkg-dev
	findutils
	flex
	openssl-dev
	perl
	lld
	llvm
"

# Source
_repository="linux"
_patches_repo="distribution"
_pkgver="7.0.10"
_commit="ca50938cbc2762d77203e1f63b8b8aa85a75f4a4"
_config="config-$_flavor.$arch"
source="
	$pkgname-$_pkgver.tar.gz::https://www.kernel.org/pub/${_repository}/kernel/v${_pkgver/.*/}.x/linux-${_pkgver}.tar.gz
	$_patches_repo-$_commit.tar.gz::https://github.com/ROCKNIX/$_patches_repo/archive/$_commit.tar.gz
	remove-joypad.patch
	patch.files
	$_config
"
builddir="$srcdir/$_repository-$_pkgver"
_outdir="out"

prepare() {
	
	# Apply select patches to the mainline kernel.
	while IFS="" read -r _i || [ -n "$_i" ]; do
		patch -p1 < "$srcdir/$_patches_repo-$_commit/$_i"
	done < "$srcdir/patch.files"

	makefile="$builddir/arch/arm64/boot/dts/allwinner/Makefile"

	for dts in "$srcdir/$_patches_repo"-*/projects/ROCKNIX/devices/H700/linux/dts/allwinner/*dts*; do
		dtb="$(basename "$dts" | sed 's/\.dts$/.dtb/')"

		# Move the devicetree sources in the kernel tree.
		cp "$dts" "arch/arm64/boot/dts/allwinner/"

		# Mention the devicetree blobs in the Makefile for
		# compilation if they're absent.
		if ! grep -q "$dtb" "$makefile"; then
			echo "dtb-\$(CONFIG_ARCH_SUNXI) += $dtb" >> "$makefile"
		fi
	done

	default_prepare
	REPLACE_GCCH=0

	REPLACE_GCCH=0 LLVM=1 \
		. downstreamkernel_prepare

}

build() {
	unset LDFLAGS
	make O="$_outdir" ARCH="$_carch" LLVM=1 \
		KBUILD_BUILD_VERSION="$((pkgrel + 1 ))-postmarketOS"
}

package() {
	downstreamkernel_package \
		"$builddir" "$pkgdir" "$_carch" "$_flavor" "$_outdir"

	mkdir -p "$pkgdir/boot/dtbs"

	for dtb in "$_outdir/arch/$_carch/boot/dts/"*.dtb "$_outdir/arch/$_carch/boot/dts/"*/*.dtb; do
		if [ -f "$dtb" ]; then
			cp -v "$dtb" "$pkgdir/boot/dtbs/"
		fi
	done
}

