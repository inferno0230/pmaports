maintainer=""
pkgname=firmware-lenovo-a6020
pkgver=3
pkgrel=0
_commit="66b5f6663ab52bb4ad7b38eb5a55deefb9af83f3"
pkgdesc="Firmware for Lenovo Vibe K5"
url="https://github.com/ArrowOS-Devices/android_vendor_lenovo_A6020"
subpackages="$pkgname-wcnss-nv:wcnss_nv $pkgname-venus:venus"
arch="aarch64"
license="proprietary"
options="!check !strip !archcheck !tracedeps pmb:cross-native"
makedepends="pil-squasher"
source="$pkgname-$_commit.tar.gz::https://github.com/ArrowOS-Devices/android_vendor_lenovo_A6020/archive/$_commit.tar.gz"
builddir="$srcdir/android_vendor_lenovo_A6020-$_commit/proprietary/etc/firmware"

build() {
	# venus.mbn exists already but seems a bit different
	pil-squasher venus2.mbn variant/A6020a40/venus.mdt
}

package() {
	# Linux detects squashed (.mbn) vs non-squashed (.mdt + .b*) based on
	# file contents, so it is fine to link venus.mbn to venus.mdt
	# Older kernels look for venus.mdt, newer ones directly for venus.mbn
	install -Dm644 "$builddir"/venus2.mbn \
		"$pkgdir"/usr/lib/firmware/postmarketos/qcom/venus-1.8/venus.mbn
	ln -s venus.mbn \
		"$pkgdir"/usr/lib/firmware/postmarketos/qcom/venus-1.8/venus.mdt

	install -Dm644 "$builddir"/wlan/prima/WCNSS_qcom_wlan_nv.bin \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/wlan/prima
}

venus() {
	pkgdesc="Lenovo Vibe K5 video firmware"

	amove usr/lib/firmware/postmarketos/qcom/venus-1.8/venus.mbn
	amove usr/lib/firmware/postmarketos/qcom/venus-1.8/venus.mdt
}

wcnss_nv() {
	pkgdesc="Lenovo Vibe K5 WiFi/BT firmware configuration"

	amove usr/lib/firmware/postmarketos/wlan/prima/WCNSS_qcom_wlan_nv.bin
}

sha512sums="
863d953663d8e070402460ddf8d4f550ce30e3e5ef3cca182cbd6770fc5269f533d81ae0c69c5254e929639dda58398f45694accb22597049ff91e0fb0ee92ca  firmware-lenovo-a6020-66b5f6663ab52bb4ad7b38eb5a55deefb9af83f3.tar.gz
"
