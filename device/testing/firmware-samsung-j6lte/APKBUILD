maintainer="methanal <baclofen@tuta.io>"
pkgname=firmware-samsung-j6lte
pkgver=3
pkgrel=0
_commit="c69a2f7405aeadf3eac6a1e9aa870608707022a2"
pkgdesc="Firmware for Samsung Galaxy J6 (2018)"
url="https://gitlab.com/exynos7870-mainline/firmware"
arch="aarch64"
license="proprietary"
source="https://gitlab.com/exynos7870-mainline/firmware/-/archive/$_commit/firmware-$_commit.tar.gz"
options="!archcheck !check !spdx !strip !tracedeps pmb:cross-native"
builddir="$srcdir/firmware-$_commit/j6lte"

package() {
	# Bluetooth firmware (Broadcom BCM43430B0)
	install -Dm644 "$builddir"/bluetooth_bcm.hcd \
		"$pkgdir"/usr/lib/firmware/postmarketos/brcm/BCM43430B0.hcd

	# Wi-Fi SDIO firmware (Broadcom BCM43430B0)
	install -Dm644 "$builddir"/wlansdio_bcm.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/brcm/brcmfmac43430b0-sdio.bin
	install -Dm644 "$builddir"/wlansdio_bcm.clm_blob \
		"$pkgdir"/usr/lib/firmware/postmarketos/brcm/brcmfmac43430b0-sdio.clm_blob
	install -Dm644 "$builddir"/wlansdio_bcm.txt \
		"$pkgdir"/usr/lib/firmware/postmarketos/brcm/brcmfmac43430b0-sdio.txt
}
sha512sums="
