maintainer=""
pkgname=firmware-samsung-a7-wcnss-nv
pkgver=2
pkgrel=0
pkgdesc="WiFi/BT Firmware for Samsung Galaxy A7 (2015)"
url="https://postmarketos.org"
arch="aarch64"
license="proprietary"
source="$pkgname-WCNSS_qcom_wlan_nv.bin.base64::https://pastebin.com/raw/qqXtjvd0"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir"

build() {
	base64 -d $pkgname-WCNSS_qcom_wlan_nv.bin.base64 > WCNSS_qcom_wlan_nv.bin
}

package() {
	install -Dm644 "$srcdir"/WCNSS_qcom_wlan_nv.bin \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/wlan/prima/
}

