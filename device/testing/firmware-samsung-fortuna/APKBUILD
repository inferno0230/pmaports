maintainer="Raymond Hackley <wonderfulShrineMaidenOfParadise@postmarketos.org>"
pkgname=firmware-samsung-fortuna
pkgver=3
pkgrel=0
pkgdesc="Firmware for Samsung Galaxy Grand Prime"
url="https://postmarketos.org"
arch="aarch64"
license="proprietary"
subpackages="
	firmware-samsung-fortuna3g-wcnss-nv:wcnss_nv_fortuna3g
	firmware-samsung-fortunaltezt-wcnss-nv:wcnss_nv_fortunaltezt:armv7
	firmware-samsung-gprimeltecan-wcnss-nv:wcnss_nv_gprimeltecan
	firmware-samsung-grandprimelte-wcnss-nv:wcnss_nv_grandprimelte
	"
source="
	firmware-samsung-fortuna3g-WCNSS_qcom_wlan_nv.bin.base64::https://pastebin.com/raw/Y8DvfvRf
	firmware-samsung-fortunaltezt-WCNSS_qcom_wlan_nv.bin.base64::https://pastebin.com/raw/s25mBaen
	firmware-samsung-gprimeltecan-WCNSS_qcom_wlan_nv.bin.base64::https://pastebin.com/raw/BxjvzZhd
	firmware-samsung-grandprimelte-WCNSS_qcom_wlan_nv.bin.base64::https://pastebin.com/raw/6rPpqqEE
	"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir"

_fwdir="/usr/lib/firmware/postmarketos"

build() {
	local variant
	for variant in fortuna3g fortunaltezt gprimeltecan grandprimelte; do
		base64 -d firmware-samsung-$variant-WCNSS_qcom_wlan_nv.bin.base64 \
			> $variant-WCNSS_qcom_wlan_nv.bin
	done
}

package() {
	# parent package is empty
	mkdir -p "$pkgdir"
}

wcnss_nv_fortuna3g() {
	pkgdesc="Samsung Galaxy Grand Prime (SM-G530H) WiFi/BT firmware configuration"
	install -Dm644 "$srcdir"/fortuna3g-WCNSS_qcom_wlan_nv.bin \
		"$subpkgdir/$_fwdir"/wlan/prima/WCNSS_qcom_wlan_nv.bin
}

wcnss_nv_fortunaltezt() {
	pkgdesc="Samsung Galaxy Grand Prime (SM-G530Y) WiFi/BT firmware configuration"
	install -Dm644 "$srcdir"/fortunaltezt-WCNSS_qcom_wlan_nv.bin \
		"$subpkgdir/$_fwdir"/wlan/prima/WCNSS_qcom_wlan_nv.bin
}

wcnss_nv_gprimeltecan() {
	pkgdesc="Samsung Galaxy Grand Prime (SM-G530W) WiFi/BT firmware configuration"
	install -Dm644 "$srcdir"/gprimeltecan-WCNSS_qcom_wlan_nv.bin \
		"$subpkgdir/$_fwdir"/wlan/prima/WCNSS_qcom_wlan_nv.bin
}

wcnss_nv_grandprimelte() {
	pkgdesc="Samsung Galaxy Grand Prime (SM-G530FZ) WiFi/BT firmware configuration"
	install -Dm644 "$srcdir"/grandprimelte-WCNSS_qcom_wlan_nv.bin \
		"$subpkgdir/$_fwdir"/wlan/prima/WCNSS_qcom_wlan_nv.bin
}

