maintainer="Kevin Widjaja <kevinwidjaja_dev@proton.me>"
pkgname=u-boot-anbernic-rgxxxx
pkgver=2025.10
pkgrel=0
_atf_ver="2.13.0"
pkgdesc="U-Boot bootloader for Anbernic RGXXXX H700"
url="https://www.denx.de/wiki/U-Boot"
arch="aarch64"
license="GPL-2.0-or-later OFL-1.1 BSD-2-Clause BSD-3-Clause eCos-2.0 IBM-pibs ISC LGPL-2.0-only LGPL-2.1-only X11"
makedepends="
	$depends_dev
	bc
	bison
	dtc
	flex
	gnutls-dev
	openssl-dev
	py3-setuptools
	python3-dev
	swig
	gcc-aarch64-none-elf
	"
options="!check !tracedeps"
_pkgver="v2025.10"
source="
	u-boot-$_pkgver.tar.gz::https://github.com/u-boot/u-boot/archive/$_pkgver.tar.gz
	https://github.com/TrustedFirmware-A/trusted-firmware-a/archive/v$_atf_ver.tar.gz
	anbernic_rg35xx_h700_defconfig.patch
	"
builddir="$srcdir/u-boot-${_pkgver#v}"
_atf_builddir="$srcdir/trusted-firmware-a-$_atf_ver"

build() {
	msg "Building ARM Trusted Firmware for sun50i_h616"
	cd "$_atf_builddir"

	unset AR AS CC CPP CXX LD NM OBJCOPY OBJDUMP STRIP RANLIB
	unset CPPFLAGS CFLAGS CXXFLAGS LDFLAGS

	CROSS_COMPILE="${CROSS_COMPILE}" CFLAGS="-ffat-lto-objects" make PLAT=sun50i_h616 bl31

	export BL31="$_atf_builddir/build/sun50i_h616/release/bl31.bin"

	msg "Building U-Boot"
	cd "$builddir"

	touch include/config.h
	LC_ALL=C date +'#define U_BOOT_DATE "%b %d %C%y"' > include/timestamp_autogenerated.h
	LC_ALL=C date +'#define U_BOOT_TIME "%T"' >> include/timestamp_autogenerated.h

	export BUILD_DIR="$builddir"/build

	make O="$BUILD_DIR" ARCH=arm anbernic_rg35xx_h700_defconfig
	make O="$BUILD_DIR" ARCH=arm BL31="$BL31" all

	sha512sum -b "$BUILD_DIR/u-boot-sunxi-with-spl.bin" > "$BUILD_DIR/u-boot-sunxi-with-spl.bin.sha512"
}

package() {
	install -D -m644 "build/u-boot-sunxi-with-spl.bin" \
		"$pkgdir/usr/share/u-boot/anbernic-rg35xx/u-boot-sunxi-with-spl.bin"
	install -D -m644 "build/u-boot-sunxi-with-spl.bin.sha512" \
		"$pkgdir/usr/share/u-boot/anbernic-rg35xx/u-boot-sunxi-with-spl.bin.sha512"
}

