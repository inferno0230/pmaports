bdec8f46dd3f6871366bff92e95e8cc7f8291bec2dd06052e94e8b2c3be62952ccd00c8d626c8cc7fa50bb417ca168cccf1c6f3cff3fe242596f949a96660455  config-postmarketos-qcom-msm8227.armv7
"
