From 276ecd2bfecda2401903c450eb7e2f5eacbc8d89 Mon Sep 17 00:00:00 2001
From: Hugo Osvaldo Barrera <hugo@whynothugo.nl>
Date: Thu, 11 Jun 2026 22:07:17 +0200
Subject: [PATCH] fydetab-duo: new device support

Properly boots and loads the kernel. The display doesn't turn on, so
output is only visible via the (internal) UART connector.
---
 arch/arm/dts/rk3588s-fydetab-duo-u-boot.dtsi |  9 +++
 arch/arm/dts/rk3588s-fydetab-duo.dts         | 85 ++++++++++++++++++++
 configs/fydetab-duo-rk3588s_defconfig        | 70 ++++++++++++++++
 3 files changed, 164 insertions(+)
 create mode 100644 arch/arm/dts/rk3588s-fydetab-duo-u-boot.dtsi
 create mode 100644 arch/arm/dts/rk3588s-fydetab-duo.dts
 create mode 100644 configs/fydetab-duo-rk3588s_defconfig

diff --git a/arch/arm/dts/rk3588s-fydetab-duo-u-boot.dtsi b/arch/arm/dts/rk3588s-fydetab-duo-u-boot.dtsi
new file mode 100644
index 00000000000..f7a1c8f97dd
--- /dev/null
+++ b/arch/arm/dts/rk3588s-fydetab-duo-u-boot.dtsi
@@ -0,0 +1,9 @@
+// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
+
+#include "rk3588s-u-boot.dtsi"
+
+/ {
+	chosen {
+		u-boot,spl-boot-order = "same-as-spl", &sdmmc, &sdhci;
+	};
+};
diff --git a/arch/arm/dts/rk3588s-fydetab-duo.dts b/arch/arm/dts/rk3588s-fydetab-duo.dts
new file mode 100644
index 00000000000..96a01ac72e3
--- /dev/null
+++ b/arch/arm/dts/rk3588s-fydetab-duo.dts
@@ -0,0 +1,85 @@
+// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
+
+/dts-v1/;
+#include <dt-bindings/gpio/gpio.h>
+#include <dt-bindings/input/linux-event-codes.h>
+#include "rk3588s.dtsi"
+
+/ {
+	model = "Fydetab Duo";
+	compatible = "fydeos,fydetab-duo", "rockchip,rk3588";
+
+	aliases {
+		mmc0 = &sdhci;
+		mmc1 = &sdmmc;
+	};
+
+	chosen {
+		stdout-path = "serial2:1500000n8";
+	};
+
+	adc-keys {
+		compatible = "adc-keys";
+		io-channels = <&saradc 1>;
+		io-channel-names = "buttons";
+		keyup-threshold-microvolt = <1800000>;
+		status = "okay";
+
+		volumeup-key {
+			linux,code = <KEY_VOLUMEUP>;
+			label = "volume up";
+			press-threshold-microvolt = <1750>;
+		};
+
+		volumedown-key {
+			linux,code = <KEY_VOLUMEDOWN>;
+			label = "volume down";
+			press-threshold-microvolt = <500000>;
+		};
+	};
+
+	vcc_sd: vcc-sd-power {
+		compatible = "regulator-fixed";
+		regulator-name = "vcc_sd";
+		enable-active-high;
+		regulator-always-on;
+		regulator-boot-on;
+		gpio = <&gpio4 RK_PB4 GPIO_ACTIVE_HIGH>;
+		pinctrl-names = "default";
+		pinctrl-0 = <&vcc_sd_en_pin>;
+	};
+};
+
+&sdhci {
+	bus-width = <8>;
+	cap-mmc-highspeed;
+	mmc-hs200-1_8v;
+	no-sd;
+	no-sdio;
+	non-removable;
+	status = "okay";
+};
+
+&sdmmc {
+	bus-width = <4>;
+	cap-sd-highspeed;
+	disable-wp;
+	no-mmc;
+	no-sdio;
+	cd-gpios = <&gpio0 RK_PA4 GPIO_ACTIVE_LOW>;
+	vmmc-supply = <&vcc_sd>;
+	status = "okay";
+};
+
+&uart2 {
+	pinctrl-0 = <&uart2m0_xfer>;
+	status = "okay";
+};
+
+&pinctrl {
+	sdcard {
+		vcc_sd_en_pin: vcc-sd-en-pin {
+			rockchip,pins = <4 RK_PB4 RK_FUNC_GPIO &pcfg_pull_none>;
+		};
+	};
+};
diff --git a/configs/fydetab-duo-rk3588s_defconfig b/configs/fydetab-duo-rk3588s_defconfig
new file mode 100644
index 00000000000..d8e07db920b
