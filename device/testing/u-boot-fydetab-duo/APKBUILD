# Contributor: Hugo Osvaldo Barrera <hugo@whynothugo.nl>
maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=u-boot-fydetab-duo
pkgver=2026.04
pkgrel=0
pkgdesc="U-Boot for Fydetab Duo using Rockchip next-dev branch"
arch="aarch64"
license="GPL-2.0"
url="https://github.com/rockchip-linux/u-boot"
makedepends="
	arm-trusted-firmware
	bash
	bc
	bison
	coreutils
	dtc
	flex
	gnutls-dev
	openssl-dev
	python3
	py3-elftools
	py3-setuptools
	python3-dev
	swig
	u-boot-tools
"
options="!check !tracedeps"
_rkbin_commit="74213af1e952c4683d2e35952507133b61394862"
_ddr_ver=1.19
source="
	ftp://ftp.denx.de/pub/u-boot/u-boot-${pkgver//_/-}.tar.bz2
	https://github.com/rockchip-linux/rkbin/raw/$_rkbin_commit/bin/rk35/rk3588_ddr_lp4_2112MHz_lp5_2400MHz_v$_ddr_ver.bin
	https://github.com/rockchip-linux/rkbin/raw/$_rkbin_commit/bin/rk35/rk3588_bl32_v1.20.bin
	0001-fydetab-duo-new-device-support.patch
	update-u-boot
"
builddir="$srcdir"/u-boot-${pkgver//_/-}

build() {
	touch include/config.h
	LC_ALL=C date +'#define U_BOOT_DATE "%b %d %C%y"' >include/timestamp_autogenerated.h
	LC_ALL=C date +'#define U_BOOT_TIME "%T"' >>include/timestamp_autogenerated.h

	export ROCKCHIP_TPL="$srcdir"/rk3588_ddr_lp4_2112MHz_lp5_2400MHz_v$_ddr_ver.bin
	export BL31="/usr/share/arm-trusted-firmware/rk3588/bl31.elf"
	# export TEE="$srcdir"/rk3588_bl32_v1.20.bin
	export KCFLAGS="-Wno-enum-int-mismatch -Wno-maybe-uninitialized"

	make fydetab-duo-rk3588s_defconfig
	make

	# Create idbloader.img
	mkimage -n rk3588 -T rksd -d "$ROCKCHIP_TPL:$builddir/spl/u-boot-spl.bin" "$builddir"/idbloader.img
}

package() {
	install -Dm 755 -t "$pkgdir"/usr/sbin/ "$srcdir"/update-u-boot
	install -Dm 644 -t "$pkgdir"/usr/share/u-boot/fydetab-duo \
		"$builddir"/idbloader.img \
		"$builddir"/u-boot.itb
}

