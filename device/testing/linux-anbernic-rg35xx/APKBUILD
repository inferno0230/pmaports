pkgname=linux-anbernic-rg35xx
pkgver=6.15.2
pkgrel=0
pkgdesc="Anbernic RG35XX SP kernel fork"
arch="aarch64"
_carch="arm64"
_flavor="anbernic-rg35xx"
url="https://kernel.org"
license="GPL-2.0-only"
options="!strip !check !tracedeps pmb:cross-native"
makedepends="
	bash
	bc
	bison
	devicepkg-dev
	findutils
	flex
	openssl-dev
	perl
"

# Source
_repository="linux"
_commit="6.15.2"
_config="config-$_flavor.$arch"
source="
	$pkgname-$_commit.tar.gz::https://www.kernel.org/pub/${_repository}/kernel/v${_commit/.*/}.x/linux-${_commit}.tar.gz
	$_config
	0001-v8_20250310_ryan_drm_sun4i_add_display_engine_3_3_de33_support.patch
	0003-20250216_ryan_arm64_dts_allwinner_h616_add_lcd_timing_controller_and_display_engine_support.patch
	0004-v3_20250215_ryan_asoc_sun4i_codec_add_headphone_dectection_for_anbernic_rg35xx_devices.patch
	0005-v2_20250416_andre_przywara_arm64_sunxi_h616_enable_mali_gpu.patch
	0006-v2_20250403_simons_philippe_drm_panfrost_enable_g31_on_h616.patch
	0007-rg35xx-add-GPU-opp.patch
	0008-sun20i-add-pwm-driver.patch
	0009-h616-add-pwm-node.patch
	0010-rg35xx-enable-pwm-backlight.patch
	0040-Revert-usb-musb-Fix-hardware-lockup-on-first-Rx-endp.patch
	0110-v2_20250226_kikuchan98_drm_panel_add_generic_mipi_panel_driver.patch
	0111-rg35xx-2024-use-panel-mipi-dpi-spi-driver.patch
	0124-battery-name.patch
	0126-20241018_macroalpha82_rg35xx_add_additional_hardware_support.patch
	0127-enable-mmc1-for-RG35XX-2024.patch
	0133-add-rg35xx-panel-variants-dts.patch
	0151-phy-fix-OTG-host-mode.patch
	0152-rg35xx-2024-enable-usb-otg.patch
	0155-sun4i-set-rgb-connector-as-DSI.patch
	0200-h700-update-opps.patch
	0201-drm-sun4i-add-TCON-global-control-reg-for-pad-select.patch
	0901-dts-rg35xx-2024-fix-led-1-color.patch
"
builddir="$srcdir/$_repository-$_commit"
_outdir="out"

prepare() {
	default_prepare
	REPLACE_GCCH=0
	. downstreamkernel_prepare
}

build() {
	unset LDFLAGS
	make O="$_outdir" ARCH="$_carch" CC="${CC:-gcc}" \
		KBUILD_BUILD_VERSION="$((pkgrel + 1 ))-postmarketOS"

	make O="$_outdir" ARCH="$_carch" CC="${CC:-gcc}" \
		allwinner/sun50i-h700-anbernic-rg35xx-2024-rev6-panel.dtb \
		allwinner/sun50i-h700-anbernic-rg35xx-h-rev6-panel.dtb \
		allwinner/sun50i-h700-anbernic-rg35xx-plus-rev6-panel.dtb \
		allwinner/sun50i-h700-anbernic-rg35xx-sp-v2-panel.dtb
}

package() {
	downstreamkernel_package \
		"$builddir" "$pkgdir" "$_carch" "$_flavor" "$_outdir"

	mkdir -p "$pkgdir/boot/dtbs"

	for dtb in "$_outdir/arch/$_carch/boot/dts/"*.dtb "$_outdir/arch/$_carch/boot/dts/"*/*.dtb; do
		if [ -f "$dtb" ]; then
			cp -v "$dtb" "$pkgdir/boot/dtbs/"
		fi
	done
}

