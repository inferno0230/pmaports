maintainer="Frieder Hannenheim <git@fhannenheim.net>"
pkgname=firmware-oneplus-instantnoodlep
pkgver=2
pkgrel=0
_commit="2dce2681689fcf615198c663555c5a7c7b3650ba"
pkgdesc="Firmware for OnePlus 8 Pro (instantnoodlep)"
url="https://github.com/pangwalla/oneplus-instantnoodlep-firmware"
arch="aarch64"
license="proprietary"
makedepends="
	qca-swiss-army-knife
	pil-squasher
	"
replaces="
	linux-firmware-ath11k
	linux-firmware-qca
	linux-firmware-qcom
	"
subpackages="
	$pkgname-adsp:adsp
	$pkgname-bluetooth:bluetooth
	$pkgname-cdsp:cdsp
	$pkgname-gpu:gpu
	$pkgname-ipa:ipa
	$pkgname-modem:modem
	$pkgname-slpi:slpi
	$pkgname-wifi:wifi
	$pkgname-venus:venus
	"
source="https://github.com/pangwalla/oneplus-instantnoodlep-firmware/archive/$_commit/oneplus-instantnoodlep-firmware-$_commit.tar.gz"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir/oneplus-instantnoodlep-firmware-$_commit"

build() {
	pil-squasher adsp.mbn adsp/adsp.mdt
	pil-squasher cdsp.mbn cdsp/cdsp.mdt
	pil-squasher ipa_fws.mbn ipa/ipa_fws.mdt
	pil-squasher ipa_uc.mbn ipa/ipa_uc.mdt
	pil-squasher slpi.mbn slpi/slpi.mdt
	pil-squasher venus.mbn venus/venus.mdt
	cd wlan
	ath11k-bdencoder -c board-2.json
}

package() {
	install -Dm644 adsp.mbn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/
	install -Dm644 cdsp.mbn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/
	install -Dm644 ipa_fws.mbn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/
	install -Dm644 ipa_uc.mbn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/
	install -Dm644 slpi.mbn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/
	install -Dm644 wlan/board-2.bin \
		-t "$pkgdir"/usr/lib/firmware/ath11k/QCA6390/hw2.0/
	install -Dm644 wlan/amss.bin \
		-t "$pkgdir"/usr/lib/firmware/ath11k/QCA6390/hw2.0/
	install -Dm644 wlan/m3.bin \
		-t "$pkgdir"/usr/lib/firmware/ath11k/QCA6390/hw2.0/
	install -Dm644 venus.mbn \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/venus.mbn

	for file in bluetooth/*; do
		install -Dm644 "$file" \
			-t "$pkgdir"/usr/lib/firmware/qca/
	done
	for file in gpu/*; do
		install -Dm644 "$file" \
			-t "$pkgdir"/usr/lib/firmware/qcom/
	done
	for file in modem/*; do
		install -Dm644 "$file" \
			-t "$pkgdir"/usr/lib/firmware/qcom/sdx55m/
	done
}

adsp() {
	amove usr/lib/firmware/postmarketos/adsp.mbn
}

bluetooth() {
	amove usr/lib/firmware/qca
}

cdsp() {
	amove usr/lib/firmware/postmarketos/cdsp.mbn
}

gpu() {
	for file in $(ls "$builddir"/gpu/); do
		amove usr/lib/firmware/qcom/"$file"
	done
}

ipa() {
	amove usr/lib/firmware/postmarketos/ipa_fws.mbn
	amove usr/lib/firmware/postmarketos/ipa_uc.mbn
}

modem() {
	amove usr/lib/firmware/qcom/sdx55m
}

slpi() {
	amove usr/lib/firmware/postmarketos/slpi.mbn
}

wifi() {
	amove usr/lib/firmware/ath11k/QCA6390/hw2.0/board-2.bin
	amove usr/lib/firmware/ath11k/QCA6390/hw2.0/amss.bin
	amove usr/lib/firmware/ath11k/QCA6390/hw2.0/m3.bin
}

venus() {
	amove usr/lib/firmware/postmarketos/venus.mbn
}

sha512sums="
c2855805e6327977fbd119ed89e76010586273008260c4df827622266f42dc318abf7f61f78408596377338cf36c03dd10b7279b6e6f7986569c970fffae72da  oneplus-instantnoodlep-firmware-2dce2681689fcf615198c663555c5a7c7b3650ba.tar.gz
"
