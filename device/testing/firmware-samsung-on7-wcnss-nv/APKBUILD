maintainer=""
pkgname=firmware-samsung-on7-wcnss-nv
pkgver=1
pkgrel=0
pkgdesc="WiFi/BT firmware for Samsung Galaxy On7 (2015)"
url="https://postmarketos.org"
arch="aarch64"
license="proprietary"
source="$pkgname-WCNSS_qcom_wlan_nv.bin.base64::https://pastebin.com/raw/4c9b2b94"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir"

build() {
	base64 -d $pkgname-WCNSS_qcom_wlan_nv.bin.base64 > WCNSS_qcom_wlan_nv.bin
}

package() {
	install -Dm644 "$srcdir"/WCNSS_qcom_wlan_nv.bin \
		-t "$pkgdir"/usr/lib/firmware/postmarketos/wlan/prima/
}

