maintainer="Luca Weiss <luca@lucaweiss.eu>"
pkgname=firmware-fairphone-fp5
pkgver=20250623
pkgrel=1
_commit="a4908f548e6f88965e78b1478af1751b6a854fc9"
pkgdesc="Firmware for Fairphone 5"
subpackages="
	$pkgname-adreno
	$pkgname-adsp
	$pkgname-audio
	$pkgname-bluetooth
	$pkgname-cdsp
	$pkgname-hexagonfs
	$pkgname-ipa
	$pkgname-modem
	$pkgname-venus
	$pkgname-wpss
	"
url="https://github.com/FairBlobs/FP5-firmware"
arch="aarch64"
license="proprietary"
makedepends="pil-squasher"
source="https://github.com/FairBlobs/FP5-firmware/archive/$_commit/FP5-firmware-$_commit.tar.gz"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir/FP5-firmware-$_commit"

build() {
	for i in *.mdt; do
		pil-squasher "$(basename "$i" .mdt)".mbn "$i"
	done
}

package() {
	install -Dm644 "$builddir"/a660_zap.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/qcm6490/fairphone5/
	install -Dm644 "$builddir"/adsp.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/qcm6490/fairphone5/
	install -Dm644 "$builddir"/adsp*.jsn \
		-t "$pkgdir"/usr/lib/firmware/qcom/qcm6490/fairphone5/
	install -Dm644 "$builddir"/battmgr.jsn \
		-t "$pkgdir"/usr/lib/firmware/qcom/qcm6490/fairphone5/
	install -Dm644 "$builddir"/aw882xx_acf.bin \
		"$pkgdir"/usr/lib/firmware/qcom/qcm6490/fairphone5/aw88261_acf.bin
	install -Dm644 "$builddir"/msbtfw11.mbn \
		-t "$pkgdir"/usr/lib/firmware/qca/
	install -Dm644 "$builddir"/msnv11.bin \
		-t "$pkgdir"/usr/lib/firmware/qca/
	install -Dm644 "$builddir"/cdsp.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/qcm6490/fairphone5/
	install -Dm644 "$builddir"/cdsp*.jsn \
		-t "$pkgdir"/usr/lib/firmware/qcom/qcm6490/fairphone5/
	install -Dm644 "$builddir"/yupik_ipa_fws.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/qcm6490/fairphone5/ipa_fws.mbn
	install -Dm644 "$builddir"/modem.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/qcm6490/fairphone5/
	install -Dm644 "$builddir"/modem*.jsn \
		-t "$pkgdir"/usr/lib/firmware/qcom/qcm6490/fairphone5/
	install -Dm644 "$builddir"/vpu20_1v.mbn \
		"$pkgdir"/usr/lib/firmware/qcom/qcm6490/fairphone5/venus.mbn
	install -Dm644 "$builddir"/wpss.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/qcm6490/fairphone5/

	cp -r "$builddir"/modem_pr/ \
		"$pkgdir"/usr/lib/firmware/qcom/qcm6490/fairphone5/
	# Used `cp` to move subdirectories, so we need to set the perms manually
	find "$pkgdir"/usr/lib/firmware/qcom/qcm6490/fairphone5/ \
		-type f -exec chmod 0644 {} \;

	mkdir -p "$pkgdir"/usr/share/qcom/qcm6490/Fairphone/fp5
	cp -r "$builddir"/hexagonfs/* \
		"$pkgdir"/usr/share/qcom/qcm6490/Fairphone/fp5
	# Remove files that we don't need - for now
	rm -r "$pkgdir"/usr/share/qcom/qcm6490/Fairphone/fp5/acdb/
	rm -r "$pkgdir"/usr/share/qcom/qcm6490/Fairphone/fp5/dsp/
	# Used `cp` to move subdirectories, so we need to set the perms manually
	find "$pkgdir"/usr/share/qcom/qcm6490/Fairphone/fp5/ \
		-type f -exec chmod 0644 {} \;
}

adreno() {
	pkgdesc="Fairphone 5 adreno firmware"

	amove usr/lib/firmware/qcom/qcm6490/fairphone5/a660_zap.mbn
}

adsp() {
	pkgdesc="Fairphone 5 adsp firmware"

	amove usr/lib/firmware/qcom/qcm6490/fairphone5/adsp.mbn
	amove usr/lib/firmware/qcom/qcm6490/fairphone5/adsp*.jsn
	amove usr/lib/firmware/qcom/qcm6490/fairphone5/battmgr.jsn
}

audio() {
	pkgdesc="Fairphone 5 audio amplifier firmware"

	amove usr/lib/firmware/qcom/qcm6490/fairphone5/aw88261_acf.bin
}

bluetooth() {
	pkgdesc="Fairphone 5 bluetooth firmware"

	amove usr/lib/firmware/qca/msbtfw11.mbn
	amove usr/lib/firmware/qca/msnv11.bin
}

cdsp() {
	pkgdesc="Fairphone 5 cdsp firmware"

	amove usr/lib/firmware/qcom/qcm6490/fairphone5/cdsp.mbn
	amove usr/lib/firmware/qcom/qcm6490/fairphone5/cdsp*.jsn
}

hexagonfs() {
	pkgdesc="Fairphone 5 hexagonfs files"

	for i in $(ls "$builddir"/hexagonfs/); do
		amove usr/share/qcom/qcm6490/Fairphone/fp5/"$i" || true
	done
}

ipa() {
	pkgdesc="Fairphone 5 ipa firmware"

	amove usr/lib/firmware/qcom/qcm6490/fairphone5/ipa_fws.mbn
}

modem() {
	pkgdesc="Fairphone 5 modem firmware"

	amove usr/lib/firmware/qcom/qcm6490/fairphone5/modem.mbn
	amove usr/lib/firmware/qcom/qcm6490/fairphone5/modem*.jsn
	amove usr/lib/firmware/qcom/qcm6490/fairphone5/modem_pr
}

venus() {
	pkgdesc="Fairphone 5 venus firmware"

	amove usr/lib/firmware/qcom/qcm6490/fairphone5/venus.mbn
}

wpss() {
	pkgdesc="Fairphone 5 wpss firmware"

	amove usr/lib/firmware/qcom/qcm6490/fairphone5/wpss.mbn
}

sha512sums="
5fb8dd3a04d2dbc927b310363480d516e286534e34d303d8e4962fe1a95330ba69a61231131757433d1a7c4fc7afe1b63b70c8c3fd6abcbc7b98741307cb867a  FP5-firmware-a4908f548e6f88965e78b1478af1751b6a854fc9.tar.gz
"
