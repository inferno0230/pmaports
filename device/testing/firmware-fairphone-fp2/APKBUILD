maintainer="Luca Weiss <luca@lucaweiss.eu>"
pkgname=firmware-fairphone-fp2
pkgver=17.09.3
pkgrel=4
_commit="6785087409c73b046d11a5c88225d4177e172a1d"
pkgdesc="Firmware for Fairphone 2"
subpackages="$pkgname-wcnss $pkgname-adsp $pkgname-modem"
url="https://github.com/FairBlobs/FP2-firmware"
arch="armv7"
license="proprietary"
source="$pkgname-$pkgver.tar.gz::https://github.com/FairBlobs/FP2-firmware/archive/$pkgver.tar.gz
	$pkgname-WCNSS_cfg.dat::https://raw.githubusercontent.com/LineageOS/android_device_fairphone_FP2/$_commit/wifi/WCNSS_cfg.dat
	$pkgname-WCNSS_qcom_cfg.ini::https://raw.githubusercontent.com/LineageOS/android_device_fairphone_FP2/$_commit/wifi/WCNSS_qcom_cfg.ini
	$pkgname-WCNSS_qcom_wlan_nv.bin::https://raw.githubusercontent.com/LineageOS/android_device_fairphone_FP2/$_commit/wifi/WCNSS_qcom_wlan_nv.bin
	"
options="!check !strip !archcheck !tracedeps pmb:cross-native"
builddir="$srcdir/FP2-firmware-$pkgver"

package() {
	for _i in WCNSS_cfg.dat WCNSS_qcom_cfg.ini WCNSS_qcom_wlan_nv.bin; do
		install -Dm644 "$srcdir"/"$pkgname"-"$_i" \
			"$pkgdir"/usr/lib/firmware/postmarketos/wlan/prima/"$_i"
	done

	for _i in adsp.* mba.* modem.* wcnss.*; do
		install -Dm644 "$builddir"/"$_i" \
			-t "$pkgdir"/usr/lib/firmware/postmarketos/
	done
}

wcnss() {
	pkgdesc="Fairphone 2 firmware for the Qualcomm Wireless Connectivity Subsystem (WCNSS)"

	amove usr/lib/firmware/postmarketos/wcnss.*
	amove usr/lib/firmware/postmarketos/wlan/prima/WCNSS_cfg.dat
	amove usr/lib/firmware/postmarketos/wlan/prima/WCNSS_qcom_cfg.ini
	amove usr/lib/firmware/postmarketos/wlan/prima/WCNSS_qcom_wlan_nv.bin
}

adsp() {
	pkgdesc="Fairphone 2 adsp firmware"

	amove usr/lib/firmware/postmarketos/adsp.*
}

modem() {
	pkgdesc="Fairphone 2 modem firmware"

	amove usr/lib/firmware/postmarketos/modem.*
	amove usr/lib/firmware/postmarketos/mba.*
}

