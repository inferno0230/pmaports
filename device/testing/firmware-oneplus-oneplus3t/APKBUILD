maintainer=""
pkgname=firmware-oneplus-oneplus3t
pkgver=3
pkgrel=0
pkgdesc="Firmware for OnePlus 3T"
url="https://gitlab.com/DrGit/firmware-oneplus3"
arch="aarch64"
license="proprietary"
makedepends="mtools pil-squasher qca-swiss-army-knife"
_files="
