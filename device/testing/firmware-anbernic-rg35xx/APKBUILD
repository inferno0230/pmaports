pkgname=firmware-anbernic-rg35xx
pkgver=1
pkgrel=0
pkgdesc="Firmware for Anbernic RG35XX series devices"
url="https://github.com/ROCKNIX/distribution"
_repository="distribution"
_commit="9f1fab30f6bbbc22c859b0cc5097b488466efefd"
arch="aarch64"
license="proprietary"
options="!check !strip !archcheck !spdx !tracedeps pmb:cross-native"

source="
	$_repository-$_commit.tar.gz::https://github.com/ROCKNIX/$_repository/archive/$_commit.tar.gz
	panel.files
"

package() {
	cd "$srcdir/$_repository-$_commit/"
	while IFS="" read -r _i || [ -n "$_i" ]; do
		_filename=$(basename "$_i")
		_destdir="$pkgdir/lib/firmware/panels"
		[ ! -d "$_destdir" ] && mkdir -p "$_destdir"
		install -Dm644 "$_i" "$_destdir/$_filename"
	done < "$srcdir/panel.files"
}

