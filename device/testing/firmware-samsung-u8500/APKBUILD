maintainer="Stefan Hansson <newbyte@postmarketos.org>"
pkgname=firmware-samsung-u8500
pkgver=3
pkgrel=0
_commit="32362bbb61aac3e48d5e30d7ae506a31204469c0"
pkgdesc="Firmware for Samsung Galaxy devices based on ST-Ericsson U8500"
url="https://github.com/evokelektrique/samsung-u8500"
arch="armv7"
license="proprietary"
replaces="firmware-samsung-golden"
source="https://github.com/evokelektrique/samsung-u8500/archive/$_commit.tar.gz"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir/samsung-u8500-$_commit/brcm"

package() {
	mkdir -p "$pkgdir"/usr/lib/firmware/postmarketos/brcm

	local file
	for file in BCM4330B1.hcd BCM4330B1.samsung,codina.hcd \
			BCM4330B1.samsung,gavini.hcd BCM4330B1.samsung,janice.hcd BCM4334B0.hcd \
			BCM4334B0.samsung,golden.hcd BCM4334B0.samsung,kyle.hcd \
			BCM4334B0.samsung,skomer.hcd brcmfmac4330-sdio.bin \
			brcmfmac4330-sdio.samsung,codina.bin brcmfmac4330-sdio.samsung,codina.txt \
			brcmfmac4330-sdio.samsung,gavini.bin brcmfmac4330-sdio.samsung,gavini.txt \
			brcmfmac4330-sdio.samsung,janice.bin brcmfmac4330-sdio.samsung,janice.txt \
			brcmfmac4334-sdio.bin brcmfmac4334-sdio.samsung,golden.bin \
			brcmfmac4334-sdio.samsung,golden.txt brcmfmac4334-sdio.samsung,kyle.bin \
			brcmfmac4334-sdio.samsung,kyle.txt brcmfmac4334-sdio.samsung,skomer.bin \
			brcmfmac4334-sdio.samsung,skomer.txt; do
				install -m644 "$builddir"/"$file" \
					-t "$pkgdir"/usr/lib/firmware/postmarketos/brcm/
	done
}

sha512sums="
