4a5ceb68b2e84fd69b4bbcdc09eb5b7e0a3fc22a382f22f93f1f32e7407372f38a83310bb5cdf3d7ec1fbdf00e38f398768eb9c239069d1e8556cf40363b2d04  config-postmarketos-stericsson.armv7
