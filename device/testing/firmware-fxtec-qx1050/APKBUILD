maintainer=""
pkgname=firmware-fxtec-qx1050
pkgver=2
pkgrel=0
_commit="6c1ef5bce85750688f789bc6e232ca8237b24713"
pkgdesc="Firmware for F(x)tec Pro1x (QX1050)"
url="https://github.com/zstas/fxtec-pro1x-firmware"
arch="aarch64"
license="proprietary"
subpackages="
	$pkgname-adreno
	$pkgname-adsp
	$pkgname-cdsp
	$pkgname-ipa
	$pkgname-radio
	$pkgname-rproc
	$pkgname-rproc-openrc:rproc_openrc
	$pkgname-venus
	"
source="$pkgname-$_commit.tar.gz::https://github.com/sm6115-mainline/firmware-fxtec-qx1050/archive/$_commit.tar.gz"
install="$pkgname-rproc-openrc.post-install $pkgname-rproc-openrc.post-upgrade"
options="!archcheck !check !strip !tracedeps pmb:cross-native"
builddir="$srcdir/$pkgname-$_commit/lib/firmware/qcom/sm6115/Fxtec/QX1050/"

package() {
	install -Dm644 "$builddir"/a610_zap.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm6115/Fxtec/QX1050/
	install -Dm644 "$builddir"/adsp* \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm6115/Fxtec/QX1050/
	install -Dm644 "$builddir"/cdsp* \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm6115/Fxtec/QX1050/
	install -Dm644 "$builddir"/ipa_fws.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm6115/Fxtec/QX1050/
	install -Dm644 "$builddir"/modem.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm6115/Fxtec/QX1050/
	install -Dm644 "$builddir"/modem*.jsn \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm6115/Fxtec/QX1050/
	install -Dm644 "$builddir"/wlanmdsp.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm6115/Fxtec/QX1050/
	install -Dm644 "$builddir"/venus.mbn \
		-t "$pkgdir"/usr/lib/firmware/qcom/sm6115/Fxtec/QX1050/
}

adreno() {
	pkgdesc="Fxtec Pro1x (QX1050) adreno firmware"
	depends="firmware-qcom-adreno-a610"

	amove usr/lib/firmware/qcom/sm6115/Fxtec/QX1050/a610_zap.mbn
}

adsp() {
	pkgdesc="Fxtec Pro1x (QX1050) ADSP firmware"

	amove usr/lib/firmware/qcom/sm6115/Fxtec/QX1050/adsp*
}

cdsp() {
	pkgdesc="Fxtec Pro1x (QX1050) CDSP firmware"

	amove usr/lib/firmware/qcom/sm6115/Fxtec/QX1050/cdsp*
}

ipa() {
	pkgdesc="Fxtec Pro1x (QX1050) IPA firmware"

	amove usr/lib/firmware/qcom/sm6115/Fxtec/QX1050/ipa_fws.mbn
}

radio() {
	pkgdesc="Fxtec Pro1x (QX1050) radio firmware"
	depends="linux-firmware-ath10k"

	amove usr/lib/firmware/qcom/sm6115/Fxtec/QX1050/modem.mbn
	amove usr/lib/firmware/qcom/sm6115/Fxtec/QX1050/modem*.jsn
	amove usr/lib/firmware/qcom/sm6115/Fxtec/QX1050/wlanmdsp.mbn
}

rproc() {
	pkgdesc="Modem and Wifi services and configuration"
	depends="
		pd-mapper
		rmtfs
		tqftpserv
		"

	mkdir "$subpkgdir"
}

rproc_openrc() {
	install_if="$pkgname-rproc openrc"
	depends="
		openrc
		pd-mapper-openrc
		tqftpserv-openrc
		"

	mkdir "$subpkgdir"
}

venus() {
	pkgdesc="Fxtec Pro1x (QX1050) venus firmware"

	amove usr/lib/firmware/qcom/sm6115/Fxtec/QX1050/venus.mbn
}

