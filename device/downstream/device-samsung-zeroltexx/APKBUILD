# Reference: <https://postmarketos.org/devicepkg>
maintainer=""
pkgname=device-samsung-zeroltexx
pkgdesc="Samsung Galaxy S6 edge"
pkgver=5
pkgrel=0
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	postmarketos-base
	postmarketos-base-downstream-disable-udev-v4l
	linux-samsung-zeroltexx
	mkbootimg
	msm-fb-refresher
"
makedepends="devicepkg-dev"
subpackages="
	$pkgname-nonfree-firmware:nonfree_firmware
	$pkgname-openrc
	"
source="deviceinfo"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname
}

nonfree_firmware() {
	pkgdesc="Non-free firmware for the Samsung Galaxy S6 edge"
	depends="firmware-samsung-zero"
	mkdir "$subpkgdir"
}

openrc() {
	install_if="$pkgname=$pkgver-r$pkgrel openrc"
	install="$subpkgname.post-install"

	mkdir -p "$subpkgdir"
}


sha512sums="
281dff3a7da9bd09f774135fd787829166dab24fecadefed7f241b33c39a798ea0d1cb0608c43d865c3d1d6ce7d3c0744dd40d882bddcc2d3bdeb9fb72aa436b  deviceinfo
"
