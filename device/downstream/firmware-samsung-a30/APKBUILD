maintainer=""
pkgname=firmware-samsung-a30
pkgver=2
pkgrel=0
_commit="7ecb4200e64b54bb4b8add7ce35d5da2ffe4da0d"
pkgdesc="Firmware for the Samsung Galaxy A30"
url="https://github.com/crazo7924/proprietary_vendor_samsung_a30"
arch="aarch64"
license="proprietary"
source="$pkgname-$_commit.tar.gz::https://github.com/crazo7924/proprietary_vendor_samsung_a30/archive/$_commit.tar.gz"
options="!archcheck !check !spdx !strip !tracedeps pmb:cross-native"
builddir="$srcdir/proprietary_vendor_samsung_a30-$_commit/proprietary/vendor/firmware"


package() {
	#VENDOR FILES
	install -Dm644 APBargeIn_AUDIO_SLSI.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/APBargeIn_AUDIO_SLSI.bin
	install -Dm644 AP_AUDIO_SLSI.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/AP_AUDIO_SLSI.bin
	install -Dm644 calliope_dram.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/calliope_dram.bin
	install -Dm644 calliope_sram.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/calliope_sram.bin
	install -Dm644 fimc_is_lib.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/fimc_is_lib.bin
	install -Dm644 fimc_is_rta.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/fimc_is_rta.bin
	install -Dm644 mfc_fw.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/mfc_fw.bin
	install -Dm644 setfile_2p6.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/setfile_2p6.bin
	install -Dm644 setfile_3p8sp.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/setfile_3p8sp.bin
	install -Dm644 setfile_5e9.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/setfile_5e9.bin
	install -Dm644 setfile_imx471.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/setfile_imx471.bin
	install -Dm644 Tfa9896.cnt \
		"$pkgdir"/usr/lib/firmware/postmarketos/Tfa9896.cnt

	#WIFI FIRMWARE
	cd "$builddir/../etc/wifi/"
	install -Dm644 mx \
		"$pkgdir"/usr/lib/firmware/postmarketos/mx140/mx
	install -Dm644 mx140.bin \
		"$pkgdir"/usr/lib/firmware/postmarketos/mx140/mx140.bin
	install -Dm644 mx140_bt.hcf \
		"$pkgdir"/usr/lib/firmware/postmarketos/mx140/mx140_bt.hcf
	install -Dm644 mx140_wlan.hcf \
		"$pkgdir"/usr/lib/firmware/postmarketos/mx140/mx140_wlan.hcf
	install -Dm644 mx140_wlan_t.hcf \
		"$pkgdir"/usr/lib/firmware/postmarketos/mx140/mx140_wlan_t.hcf

}

