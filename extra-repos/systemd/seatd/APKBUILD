# Fork from Alpine to link to systemd-logind instead of elogind

pkgname=seatd
_pkgver=0.9.1
pkgver="999$_pkgver"
pkgrel=0
pkgdesc="Minimal seat management daemon"
url="https://sr.ht/~kennylevinsen/seatd/"
license="MIT"
# ppc64le: upsteam uses conditional compilation to silence an error
# armhf: pmb#2618
arch="all !ppc64le !armhf"
options="suid"  # needed for seatd-launch
pkggroups="seat"
install="$pkgname.pre-install $pkgname.post-install $pkgname.post-upgrade"
makedepends="meson scdoc systemd-dev linux-headers"
subpackages="libseat:libs libseat-dev $pkgname-launch $pkgname-doc"
source="$pkgname-$_pkgver.tar.gz::https://git.sr.ht/~kennylevinsen/seatd/archive/$_pkgver.tar.gz"
builddir="$srcdir/$pkgname-$_pkgver"

# secfixes:
#   0.6.2-r0:
#     - CVE-2021-41387

build() {
	abuild-meson \
		-Dlibseat-logind=systemd \
		-Dman-pages=enabled \
		. output

	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
	chmod u+s "$pkgdir"/usr/bin/seatd-launch
}

libs() {
	default_libs
	pkgdesc="Universal seat management library"
}

dev() {
	default_dev
	pkgdesc="Universal seat management library (development files)"
}

launch() {
	pkgdesc="Command to start a process with its own seatd instance (SUID binary)"
	depends="$pkgname"

	amove usr/bin/seatd-launch
}

sha512sums="
15d24a6646fa82a2bcc21d2a99693e1c54e71b9da24a0ba5c847a72c53d803410cbcee31fc847fef468b18d941d9685391bebf745819d4b24d056cd67e08c3fb  seatd-0.9.1.tar.gz
"
