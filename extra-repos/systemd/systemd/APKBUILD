# Scan for dlopened dependencies
_dump_dlopen_metadata() {
	mkdir -p "$pkgbasedir/.dlopen-metadata-tmp"
	mkdir -p "$pkgbasedir/.dlopen-metadata"
	scanelf -RyB -E ET_DYN --section '.note.dlopen' "$pkgdir" | while read type section src; do
		[ "$section" != ".note.dlopen" ] && continue

		section_data="$(readelf -j .note.dlopen "$src")"
		local filename="${src##*/}"
		if [ -e "$pkgbasedir/.dlopen-metadata/$filename" ]; then
			error "filename reused, cannot handle this yet: $filename"
		fi
		readelf -j .note.dlopen "$src" | tee "$pkgbasedir/.dlopen-metadata/$filename"
		local tmp="$pkgbasedir/.dlopen-metadata-tmp/$filename"
		strip --remove-section=.note.dlopen -o "$tmp" "$src"
		# only replace content to preserve attributes
		cat "$tmp" > "$src"
		rm "$tmp"
	done

	rm -r "$pkgbasedir/.dlopen-metadata-tmp"
}

# Extract sonames from readelf output
_extract_sonames() {
	grep 'Dlopen Metadata:' | \
	sed 's/.*"soname":\[//' | \
	sed 's/\].*//' | \
	tr ',' '\n' | \
	sed 's/"//g' | \
	sort -u
}

# Resolve each soname to package
_resolve_packages() {
	while read -r soname; do
		apk search "so:$soname" 2>/dev/null || true
	done | sed 's/-[0-9].*//' | sort -u
}


