# Reference: https://postmarketos.org/uipkg
maintainer="Ferass El Hafidi <funderscore@postmarketos.org>"
pkgname=postmarketos-ui-windowmaker
pkgver=1
pkgrel=0
pkgdesc="(X11) Window manager inspired by the NeXTSTEP user interface (stylus recommended)"
url="https://www.windowmaker.org/"
arch="noarch"
license="GPL-3.0-or-later"
depends="
	dnsmasq
	mesa-egl
	postmarketos-artwork-wallpapers
	postmarketos-base-ui
	postmarketos-base-ui-audio
	postmarketos-base-ui-networkmanager
	st
	tinydm
	unclutter-xfixes
	windowmaker
	xorg-server
	"
_pmb_recommends="
	arandr
	netsurf
	svkbd
	"
install="$pkgname-openrc.post-install"
source="autostart.sh postmarketOS.style WindowMaker"
replaces="windowmaker"
subpackages="$pkgname-openrc"
options="!check" # note: we should default to OpenRC and in addition support systemd

package() {
	install -Dm644 "$srcdir"/autostart.sh \
		-t "$pkgdir"/usr/share/WindowMaker
	install -Dm644 "$srcdir"/postmarketOS.style \
		-t "$pkgdir"/usr/share/WindowMaker/Themes

	install -Dm644 "$srcdir"/WindowMaker \
		-t "$pkgdir"/etc/WindowMaker
}

openrc() {
	install_if="$pkgname=$pkgver-r$pkgrel"
	depends="
		openrc
		networkmanager-openrc
		tinydm-openrc
		"

	mkdir -p "$subpkgdir"
}
