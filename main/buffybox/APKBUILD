# Co-Maintainer: Clayton Craft <clayton@craftyguy.net>
maintainer="Johannes Marbach <n0-0ne+gitlab@mailbox.org>"
pkgname=buffybox
pkgver=3.5.1
pkgrel=0
_commit_lvgl=85aa60d18b3d5e5588d7b247abf90198f07c8a63
pkgdesc="Framebuffer-based disk unlocker for the initramfs based on LVGL"
url="https://gitlab.postmarketos.org/postmarketOS/buffybox"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	eudev-dev
	inih-dev
	libdrm-dev
	libevdev-dev
	libinput-dev
	libxkbcommon-dev
	linux-headers
	meson
	scdoc
	"
source="
	https://gitlab.postmarketos.org/postmarketOS/buffybox/-/archive/$pkgver/buffybox-$pkgver.tar.gz
	lvgl-$_commit_lvgl.tar.gz::https://github.com/lvgl/lvgl/archive/$_commit_lvgl.tar.gz
	0001-uinput-remove-initialization-of-.time.-in-static-inp.patch
	"
# check: no tests
options="!check"
subpackages="
	$pkgname-doc
	buffyboard
	f0rmz
	iskey
	unl0kr
	unl0kr-agent:unl0kr_agent
	unl0kr-agent-systemd
	"

prepare() {
	default_prepare
	mkdir -p "$builddir/lvgl"
	mv "$srcdir/lvgl-$_commit_lvgl"/* "$builddir/lvgl"
}

build() {
	abuild-meson \
		-Dsystemd=true \
		. output
	meson compile -C output

	# iskey is built separately
	abuild-meson "$builddir"/iskey iskey_output
	meson compile -C iskey_output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
	DESTDIR="$pkgdir" meson install --no-rebuild -C iskey_output

	install -Dm755 "$builddir"/iskey_output/iskey \
		"$pkgdir"/usr/bin/iskey

	# install configs to distro directory
	mkdir -p "$pkgdir"/usr/share/unl0kr/
	mv "$pkgdir"/etc/unl0kr.conf \
		"$pkgdir"/usr/share/unl0kr/
	mkdir -p "$pkgdir"/usr/share/buffyboard/
	mv "$pkgdir"/etc/buffyboard.conf \
		"$pkgdir"/usr/share/buffyboard/
}

buffyboard() {
	pkgdesc="Touch-enabled framebuffer keyboard (not only) for vampire slayers"

	amove usr/bin/buffyboard
	amove usr/share/buffyboard/buffyboard.conf
}

f0rmz() {
	pkgdesc="Framebuffer-based form wizard for the initramfs based on LVGL"

	amove usr/bin/f0rmz
}

iskey() {
	pkgdesc="Tiny tool to check if a key is pressed"

	amove usr/bin/iskey
}

unl0kr() {
	pkgdesc="Framebuffer-based disk unlocker for the initramfs based on LVGL"
	depends="
		cryptsetup
		eudev-libs
		inih
		libdrm
		libevdev
		libinput-libs
		libxkbcommon
		"

	amove usr/bin/unl0kr
	amove usr/share/unl0kr/unl0kr.conf
}

unl0kr_agent() {
	description="Password agent for unl0kr"
	depends="unl0kr=$pkgver-r$pkgrel"

	amove usr/libexec/unl0kr-agent
}

