url="https://wiki.postmarketos.org/wiki/Duranium_(Immutable_postmarketOS)"
# check: no tests
# fhs: allow installing into /usr/local
options="!check !fhs"
depends="
	coreutils
	coldbrew
	e2fsprogs
	erofs-utils
	f0rmz
	postmarketos-base
	!postmarketos-base-apk
	postmarketos-base-systemd
	shadow
	shadow-subids
	systemd-efistub
	tar
"
# x86: f0rmz
# armhf: linux-stable, systemd
# ppc64le s390x: EFI
arch="noarch !x86 !armhf !ppc64le !s390x"
license="GPL-3.0-or-later"
subpackages="
	$pkgname-initramfs
	$pkgname-sysext-dev-tools:sysext_dev_tools
	$pkgname-sysext-tailscale:sysext_tailscale
"

