# Reference: https://postmarketos.org/uipkg
maintainer="Craig Comstock <craig@unreasonablefarm.org>"
pkgname=postmarketos-ui-shelli
pkgver=3
pkgrel=9
pkgdesc="Plain console with touchscreen gesture support"
url="https://gitlab.com/unrznbl/shelli"
arch="all"
license="GPL-3.0-or-later"
depends="
	dnsmasq
	ofono
	ofonoctl
	postmarketos-base-ui
	postmarketos-base-ui-audio
	postmarketos-base-ui-networkmanager
	shelli
	shelli-opinionated
	"
subpackages="$pkgname-openrc"
install="
	$pkgname-openrc.post-install
	$pkgname-openrc.post-upgrade
	$pkgname-openrc.pre-deinstall
	"
options="!check" # No tests

package() {
	mkdir -p "$pkgdir"
}

openrc() {
	depends="
		networkmanager-openrc
		ofono-openrc
		shelli-openrc
		"

	mkdir -p "$subpkgdir"
}
