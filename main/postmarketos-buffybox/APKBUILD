maintainer="Aster Boese <asterboese@mailbox.org>"
pkgname=postmarketos-buffybox
pkgver=1
pkgrel=0
pkgdesc="postmarketOS-specific files for buffybox programs"
url="https://postmarketos.org"
arch="noarch"
license="GPL-3.0-or-later"
subpackages="
	$pkgname-f0rmz
	$pkgname-f0rmz-fbforcerefresh:f0rmz_fbforcerefresh
	$pkgname-iskey
	$pkgname-unl0kr
	$pkgname-unl0kr-fbforcerefresh:unl0kr_fbforcerefresh
	"
source="
	10-fb-force-refresh.conf
	f0rmz.conf
	f0rmz.files
	unlock.sh
	unl0kr.conf
	unl0kr.files
	"
# check: no tests
options="!check"

package() {
	touch f0rmz iskey unl0kr
	install -Dm644 f0rmz iskey unl0kr \
		-t "$pkgdir"/usr/share/mkinitfs-triggers

	install -Dm644 "$srcdir"/f0rmz.conf \
		-t "$pkgdir"/usr/share/f0rmz

	install -Dm644 "$srcdir"/f0rmz.files \
		"$pkgdir"/usr/share/mkinitfs/files-extra/30-f0rmz.files

	install -Dm644 "$srcdir"/unl0kr.conf \
		-t "$pkgdir"/usr/share/unl0kr/

	install -Dm644 "$srcdir"/10-fb-force-refresh.conf \
		-t "$pkgdir"/usr/share/f0rmz/f0rmz.conf.d/

	install -Dm644 "$srcdir"/10-fb-force-refresh.conf \
		-t "$pkgdir"/usr/share/unl0kr/unl0kr.conf.d/

	install -Dm755 "$srcdir"/unl0kr.files \
		"$pkgdir"/usr/share/mkinitfs/files-extra/30-unl0kr.files

	install -Dm755 "$srcdir"/unlock.sh \
		"$pkgdir"/usr/bin/fde-unlock
}

f0rmz() {
	pkgdesc="$pkgdesc (f0rmz)"
	install_if="f0rmz postmarketos-base"

	amove usr/share/f0rmz/f0rmz.conf
	amove usr/share/mkinitfs-triggers/f0rmz
	amove usr/share/mkinitfs/files-extra/30-f0rmz.files
}

f0rmz_fbforcerefresh() {
	pkgdesc="force refresh quirk config (f0rmz)"
	depends="f0rmz"
	provides="f0rmz-fbforcerefresh=9999.$pkgver-r$pkgrel"
	replaces="f0rmz-fbforcerefresh"

	amove usr/share/f0rmz/f0rmz.conf.d/
}

iskey() {
	pkgdesc="$pkgdesc (iskey)"
	install_if="iskey postmarketos-base"

	amove usr/share/mkinitfs-triggers/iskey
}

unl0kr() {
	pkgdesc="$pkgdesc (unl0kr)"
	depends="unl0kr"
	install_if="unl0kr postmarketos-base"
	provides="
		postmarketos-fde-unlocker=$pkgver-r$pkgrel
		osk-sdl=$pkgver-r$pkgrel
		"
	# overrides unl0kr.conf
	replaces="unl0kr"

	amove usr/bin/fde-unlock
	amove usr/share/mkinitfs-triggers/unl0kr
	amove usr/share/mkinitfs/files-extra/30-unl0kr.files
	amove usr/share/unl0kr/unl0kr.conf
}

unl0kr_fbforcerefresh() {
	pkgdesc="force refresh quirk config (unl0kr)"
	depends="unl0kr"
	provides="unl0kr-fbforcerefresh=9999.$pkgver-r$pkgrel"
	replaces="unl0kr-fbforcerefresh"

	amove usr/share/unl0kr/unl0kr.conf.d/
}

